        "jsCode": "// CHAMBALAND — Generar HTML del Reporte v5\nconst sesionData   = $node['🗂️ Gestor de Sesión'].json;\nconst queryData    = $node['Preparar Query Zabbix'].json;\nconst etiqueta     = queryData?.etiqueta || 'General';\nconst esTodosHosts = queryData?.esTodosHosts || false;\n// FIX v14: classifyItem ampliado + filtro lastclock\nfunction classifyItem(item) {\n  const k  = (item.key_||'').toLowerCase();\n  const nm = (item.name||'').toLowerCase();\n  if (/^system\\.cpu|^proc\\.cpu|cpu\\.util|^perf_counter.*cpu/i.test(k)) return 'cpu';\n  if (/^vm\\.memory|^system\\.swap|memory\\.|mem\\./i.test(k))              return 'memory';\n  if (/^vfs\\.fs|^system\\.sw\\.packages|disk\\./i.test(k))                return 'storage';\n  if (/^net\\.if|^icmp|^net\\.tcp|^net\\.udp/i.test(k))                   return 'network';\n  if (/^system\\.(hostname|uname|uptime|localtime|boottime)|^kernel\\./i.test(k)) return 'system';\n  if (/^system\\.cpu\\.temp|^sensor|temperature/i.test(k))                return 'temperature';\n  if (/^web\\.|^proc\\.num|^net\\.tcp\\.service\\[http/i.test(k))          return 'application';\n  if (/^zabbix\\.|^agent\\./i.test(k))                                     return 'internal';\n  // Fallback: tags de Zabbix\n  const tagComp = (item.tags||[]).find(t=>t.tag==='component')?.value;\n  if (tagComp) return tagComp;\n  // Fallback: nombre del item\n  if (/cpu|processor|procesador/i.test(nm))           return 'cpu';\n  if (/memory|memoria|ram|swap/i.test(nm))            return 'memory';\n  if (/disk|disco|storage|filesystem/i.test(nm))      return 'storage';\n  if (/network|red|interface|traffic/i.test(nm))      return 'network';\n  if (/uptime|hostname|system|sistema/i.test(nm))     return 'system';\n  return 'otros';\n}\nconst zabbixItems = ($json.result || []).filter(i => {\n  // FIX v14: excluir items que nunca han sido colectados\n  if (parseInt(i.lastclock||'0') === 0) return false;\n  if (i.lastvalue === undefined || i.lastvalue === null || i.lastvalue === '') return false;\n  if (classifyItem(i) === 'internal') return false;\n  const val = String(i.lastvalue||'');\n  if (val.startsWith('{') || val.startsWith('[')) return false;\n  const nm = (i.name||'').toLowerCase();\n  if (/discovery|gathering|nvps|snmp walk|agent ping/.test(nm)) return false;\n  return true;\n});\nconst nombre       = sesionData.nombre || 'Usuario';\nconst hostNombre   = esTodosHosts ? 'Todos los hosts' : (sesionData.host?.nombre || 'Servidor');\nconst ahora        = new Date().toLocaleString('es-MX', { timeZone:'America/Mexico_City' });\nconst chatId       = ($node['Telegram Trigger'].json.message?.chat?.id || $node['Telegram Trigger'].json.callback_query?.message?.chat?.id)?.toString();\n\nif (!zabbixItems.length) {\n  return {\n    html:null, tieneReporte:false, chatId,\n    mensaje:`❌ No encontré métricas para *${hostNombre}*\\n\\n🔍 Categoría: *${etiqueta}*\\n\\nVerifica que el host tenga items con los tags correctos en Zabbix.`,\n    estadoGlobal:'Sin datos', etiqueta, hostNombre, iconoGlobal:'⚪', cantidadItems:0\n  };\n}\n\n// ── Formateador de valores ────────────────────────────────────────────────────\nfunction fmt(item) {\n  const raw = item.lastvalue;\n  const u   = (item.units || '').trim();\n  const key = (item.key_ || '').toLowerCase();\n  const v   = parseFloat(raw);\n\n  if (raw === '' || raw === null || raw === undefined)\n    return { val:'N/D', pct:0, color:'#586069', estado:'Sin dato', icon:'⚫' };\n  if (isNaN(v)) {\n    const t = String(raw).substring(0, 60);\n    return { val: t + (String(raw).length > 60 ? '…' : ''), pct:0, color:'#586069', estado:'Info', icon:'ℹ️' };\n  }\n\n  // bps / Red — antes que bytes para evitar colisión con net.if.speed\n  if (u === 'bps' || u === 'Bps' || key.match(/bits\\.in|bits\\.out/)) {\n    let d;\n    if      (v >= 1073741824) d = (v/1073741824).toFixed(2)+' Gbps';\n    else if (v >= 1048576)    d = (v/1048576).toFixed(2)+' Mbps';\n    else if (v >= 1024)       d = (v/1024).toFixed(1)+' Kbps';\n    else                      d = v.toFixed(0)+' bps';\n    return { val:d, pct:0, color:'#388bfd', estado:'Normal', icon:'🔵' };\n  }\n\n  // Porcentaje — PRIMERO (antes de conversión de bytes)\n  if (u === '%') {\n    const pct    = Math.min(100, Math.max(0, Math.round(v)));\n    const esFree = key.match(/free|avail|idle|pfree/);\n    const color  = esFree\n      ? (pct < 5 ? '#f85149' : pct < 15 ? '#d29922' : '#3fb950')\n      : (pct > 90 ? '#f85149' : pct > 75 ? '#d29922' : '#3fb950');\n    const estado = esFree\n      ? (pct < 5 ? 'CRÍTICO' : pct < 15 ? 'ADVERTENCIA' : 'Normal')\n      : (pct > 90 ? 'CRÍTICO' : pct > 75 ? 'ADVERTENCIA' : 'Normal');\n    return { val: v.toFixed(2)+'%', pct, color, estado, icon: estado==='CRÍTICO'?'🔴':estado==='ADVERTENCIA'?'🟡':'🟢' };\n  }\n\n  // Bytes → MB / GB (solo unidad B o key explícito de memoria/almacenamiento)\n  if (u === 'B' || key.match(/memory|vfs\\.fs\\.size|disk|storage/)) {\n    const isLibre = key.match(/free|avail/);\n    const isTotal = key.match(/total|size/);\n    const gb = v / 1073741824, mb = v / 1048576;\n    const display = gb >= 1 ? gb.toFixed(2)+' GB' : mb.toFixed(0)+' MB';\n    if (isTotal) return { val:display, pct:100, color:'#388bfd', estado:'Info', icon:'ℹ️' };\n    const pct = Math.min(100, Math.round(isLibre ? gb * 6.25 : (v / (16*1073741824)) * 100));\n    const color = isLibre\n      ? (pct < 20 ? '#f85149' : pct < 40 ? '#d29922' : '#3fb950')\n      : (pct > 85 ? '#f85149' : pct > 65 ? '#d29922' : '#3fb950');\n    const estado = isLibre\n      ? (pct < 20 ? 'CRÍTICO' : pct < 40 ? 'ADVERTENCIA' : 'Normal')\n      : (pct > 85 ? 'CRÍTICO' : pct > 65 ? 'ADVERTENCIA' : 'Normal');\n    return { val:display+(isLibre?' libres':''), pct, color, estado, icon: estado==='CRÍTICO'?'🔴':estado==='ADVERTENCIA'?'🟡':'🟢' };\n  }\n\n  // (Porcentaje ya manejado arriba para u==='%')\n  // Porcentaje por key — para items que reportan % sin unidad explícita\n  if (key.match(/util|pused|pfree/) && !key.match(/cpu\\.switch|interrupt|context/)) {\n    const pct   = Math.min(100, Math.max(0, Math.round(v)));\n    const esFree = key.match(/free|pfree|avail|idle/);\n    const color = esFree\n      ? (pct < 5 ? '#f85149' : pct < 15 ? '#d29922' : '#3fb950')\n      : (pct > 90 ? '#f85149' : pct > 75 ? '#d29922' : '#3fb950');\n    const estado = esFree\n      ? (pct < 5 ? 'CRÍTICO' : pct < 15 ? 'ADVERTENCIA' : 'Normal')\n      : (pct > 90 ? 'CRÍTICO' : pct > 75 ? 'ADVERTENCIA' : 'Normal');\n    return { val: v.toFixed(2)+'%', pct, color, estado, icon: estado==='CRÍTICO'?'🔴':estado==='ADVERTENCIA'?'🟡':'🟢' };\n  }\n\n  // Uptime\n  if (key.match(/uptime/)) {\n    const d = Math.floor(v/86400), h = Math.floor((v%86400)/3600), m = Math.floor((v%3600)/60);\n    return { val: d>0 ? `${d}d ${h}h ${m}m` : `${h}h ${m}m`, pct:0, color:'#3fb950', estado:'Normal', icon:'🟢' };\n  }\n\n  // Unidades especiales\n  if (['rpm','W','°C','V'].includes(u))\n    return { val: v.toFixed(1)+' '+u, pct:0, color:'#8b949e', estado:'Info', icon:'ℹ️' };\n\n  // ICMP / ping especiales\n  if (key.match(/icmp\\.loss/)) {\n    const color = v>20?'#f85149':v>5?'#d29922':'#3fb950';\n    return { val: v.toFixed(1)+'%', pct:Math.round(v), color, estado:v>20?'CRÍTICO':v>5?'ADVERTENCIA':'Normal', icon:v>20?'🔴':v>5?'🟡':'🟢' };\n  }\n  if (key.match(/icmp\\.ping/))\n    return { val: v===1?'✅ Responde':'❌ Sin respuesta', pct:0, color:v===1?'#3fb950':'#f85149', estado:v===1?'Normal':'CRÍTICO', icon:v===1?'🟢':'🔴' };\n  if (key.match(/icmp\\.rspdtime/))\n    return { val: v.toFixed(2)+' ms', pct:0, color:v<100?'#3fb950':v<500?'#d29922':'#f85149', estado:v<100?'Normal':v<500?'ADVERTENCIA':'CRÍTICO', icon:v<100?'🟢':v<500?'🟡':'🔴' };\n\n  // Genérico\n  const display = v % 1 === 0 ? v.toFixed(0) : v.toFixed(2);\n  return { val: display + (u ? ' '+u : ''), pct:0, color:'#8b949e', estado:'Normal', icon:'🟢' };\n}\n\n// ── getGrupo ──────────────────────────────────────────────────────────────────\nfunction getGrupo(key, tags) {\n  const k = key.toLowerCase();\n  const comp = (tags || []).find(t=>t.tag==='component')?.value || '';\n  // Web services\n  if (k.match(/^web\\.test|^web\\.page/))                         return '🌐 Servicios Web';\n  // CPU\n  if (k.match(/cpu/) || comp === 'cpu')                           return '🖥️ CPU';\n  // Memoria\n  if (k.match(/mem|memory|hrstorage.*memory/i) || comp === 'memory') return '🧠 Memoria';\n  // Red: network interfaces + ICMP/health checks + SNMP availability\n  if (k.match(/net\\.if|icmpping|icmppingloss|icmppingsec|bits\\.in|bits\\.out|if\\[/) ||\n      comp === 'network' || comp === 'health')                    return '🌐 Red';\n  // Almacenamiento\n  if (k.match(/vfs|disk|fs|hrstorage/i) || comp === 'storage')   return '💾 Almacenamiento';\n  // Temperatura (MikroTik y otros)\n  if (k.match(/temp/) || comp === 'temperature')                  return '🌡️ Temperatura';\n  // Sistema OS\n  if (k.match(/system\\.hw|system\\.name|system\\.loc|system\\.descr|system\\.objectid|uptime|os\\.info|kernel|sysname|firmware|serial/) ||\n      comp === 'os')                                              return '🐧 Sistema';\n  // Procesos / Zabbix internals\n  if (k.match(/zabbix\\[|wcache|preprocessing|proc|service|agent\\.ping/) ||\n      comp === 'gathering-process' || comp === 'internal-process') return '⚙️ Procesos';\n  // Sistema genérico (system tag que no es OS ni procesos)\n  if (comp === 'system')                                          return '🐧 Sistema';\n  return '📊 General';\n}\n\n// ── Post-filtro: solo grupos solicitados ─────────────────────────────────────\nconst PARTES_TO_GRUPOS = {\n  'cpu':        ['🖥️ CPU'],\n  'ram':        ['🧠 Memoria'],\n  'memoria':    ['🧠 Memoria'],\n  'memory':     ['🧠 Memoria'],\n  'disco':      ['💾 Almacenamiento'],\n  'storage':    ['💾 Almacenamiento'],\n  'red':        ['🌐 Red'],              // incluye health/ICMP por getGrupo\n  'network':    ['🌐 Red'],\n  'os':         ['🐧 Sistema'],\n  'sistema':    ['🐧 Sistema'],\n  'temperatura':['🌡️ Temperatura'],\n  'salud':      ['🌐 Red'],              // health tag → Red group\n};\nconst metricaPartes = (queryData?.metricaRaw || '').toLowerCase().split('+').map(p=>p.trim()).filter(Boolean);\nconst esGeneralFiltro = metricaPartes.length === 0 || metricaPartes.includes('general');\nconst gruposPermitidos = esGeneralFiltro\n  ? null\n  : [...new Set(metricaPartes.flatMap(p => PARTES_TO_GRUPOS[p] || []))];\n\n\nconst fmtItems    = zabbixItems.map(i => ({ ...i, f: fmt(i) }));\nconst estados     = fmtItems.map(f => f.f.estado);\nconst estadoGlobal = estados.includes('CRÍTICO') ? 'CRÍTICO' : estados.includes('ADVERTENCIA') ? 'ADVERTENCIA' : 'Normal';\nconst colorGlobal  = estadoGlobal==='CRÍTICO' ? '#f85149' : estadoGlobal==='ADVERTENCIA' ? '#d29922' : '#3fb950';\nconst iconoGlobal  = estadoGlobal==='CRÍTICO' ? '🔴' : estadoGlobal==='ADVERTENCIA' ? '🟡' : '🟢';\n\n// ── Agrupar + por host si son todos ──────────────────────────────────────────\nconst grupos = {};\nconst hostnameMap = {};  // hostid → hostname\nfor (const item of fmtItems) {\n  if (esTodosHosts && item.hosts && item.hosts[0]) {\n    hostnameMap[item.hostid] = item.hosts[0].name || item.hostid;\n  }\n  const grupo = getGrupo(item.key_ || '', item.tags || []);\n  if (gruposPermitidos && !gruposPermitidos.includes(grupo)) continue;\n  if (!grupos[grupo]) grupos[grupo] = [];\n  grupos[grupo].push(item);\n}\n\n// Ordenar grupos de mayor a menor importancia\nconst ORDEN_GRUPOS = ['🖥️ CPU','🧠 Memoria','💾 Almacenamiento','🌐 Red','🐧 Sistema','⚙️ Procesos / Agente','🌐 Servicios Web','📊 General'];\nconst gruposOrdenados = Object.entries(grupos).sort(([a],[b]) => {\n  const ia = ORDEN_GRUPOS.indexOf(a), ib = ORDEN_GRUPOS.indexOf(b);\n  return (ia===-1?99:ia) - (ib===-1?99:ib);\n});\n\n// ── Cards por grupo ───────────────────────────────────────────────────────────\nlet gruposHtml = '';\nfor (const [grupo, items] of gruposOrdenados) {\n  const cards = items.map(item => {\n    const f = item.f;\n    const bar = f.pct > 0\n      ? `<div class=\"bar-bg\"><div class=\"bar\" style=\"width:${f.pct}%;background:${f.color}\"></div></div>`\n      : '';\n    // Mostrar hostname si es \"todos los hosts\"\n    const hostTag = (esTodosHosts && item.hostid && hostnameMap[item.hostid])\n      ? `<div class=\"item-host\">🖥️ ${hostnameMap[item.hostid]}</div>`\n      : '';\n    const label = item.name.length > 55 ? item.name.substring(0,55)+'…' : item.name;\n    return `<div class=\"card\">\n      ${hostTag}\n      <div class=\"card-name\" title=\"${item.name}\">${label}</div>\n      <div class=\"card-val\" style=\"color:${f.color}\">${f.val}</div>\n      ${bar}\n      <span class=\"badge\" style=\"background:${f.color}\">${f.icon} ${f.estado}</span>\n    </div>`;\n  }).join('');\n  gruposHtml += `<div class=\"group\"><div class=\"group-title\">${grupo}</div><div class=\"grid\">${cards}</div></div>`;\n}\n\n// ── Críticos destacados ───────────────────────────────────────────────────────\nconst criticos = fmtItems.filter(i => {\n  if (i.f.estado !== 'CRÍTICO') return false;\n  const g = getGrupo(i.key_ || '', i.tags || []);\n  return gruposPermitidos ? gruposPermitidos.includes(g) : true;\n});\nconst alertasHtml = criticos.length > 0\n  ? `<div class=\"alertas\"><div class=\"alertas-title\">⚠️ Alertas Críticas (${criticos.length})</div>\n     ${criticos.map(i => {\n       const h = (esTodosHosts && i.hostid && hostnameMap[i.hostid]) ? ` [${hostnameMap[i.hostid]}]` : '';\n       return `<div class=\"alerta-item\">🔴 <b>${i.name}${h}</b>: ${i.f.val}</div>`;\n     }).join('')}</div>`\n  : '';\n\nconst html = `<!DOCTYPE html>\n<html lang=\"es\">\n<head><meta charset=\"UTF-8\">\n<style>\n*{box-sizing:border-box;margin:0;padding:0}\nbody{font-family:'Segoe UI',Arial,sans-serif;background:#0d1117;color:#c9d1d9;padding:20px}\n.header{background:linear-gradient(135deg,#161b22,#1f2937);border:1px solid #30363d;border-radius:12px;padding:22px 28px;margin-bottom:18px;display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:10px}\n.header-left h1{font-size:20px;font-weight:700;color:#e6edf3;letter-spacing:.5px}\n.header-left .sub{font-size:12px;color:#8b949e;margin-top:3px}\n.estado-badge{padding:6px 16px;border-radius:20px;font-size:13px;font-weight:700;color:#fff;background:${colorGlobal}}\n.meta{display:grid;grid-template-columns:repeat(auto-fill,minmax(180px,1fr));gap:12px;margin-bottom:18px}\n.meta-card{background:#161b22;border:1px solid #21262d;border-radius:10px;padding:14px 16px}\n.meta-label{font-size:10px;color:#8b949e;text-transform:uppercase;letter-spacing:.8px;margin-bottom:4px}\n.meta-val{font-size:14px;font-weight:600;color:#e6edf3;word-break:break-all}\n.alertas{background:#1a0a0a;border:1px solid #f85149;border-radius:10px;padding:14px 18px;margin-bottom:18px}\n.alertas-title{font-size:13px;font-weight:700;color:#f85149;margin-bottom:8px}\n.alerta-item{font-size:12px;color:#ffa07a;padding:3px 0;border-bottom:1px solid #2d1a1a}\n.alerta-item:last-child{border-bottom:none}\n.group{margin-bottom:20px}\n.group-title{font-size:14px;font-weight:700;color:#388bfd;margin-bottom:10px;padding-bottom:6px;border-bottom:1px solid #21262d}\n.grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(240px,1fr));gap:10px}\n.card{background:#161b22;border:1px solid #21262d;border-radius:10px;padding:14px;transition:border-color .2s}\n.card:hover{border-color:#388bfd}\n.item-host{font-size:10px;color:#58a6ff;font-weight:600;margin-bottom:4px;background:#0d2a4a;padding:2px 6px;border-radius:4px;display:inline-block}\n.card-name{font-size:11px;color:#8b949e;margin-bottom:6px;line-height:1.3}\n.card-val{font-size:18px;font-weight:700;margin-bottom:8px}\n.bar-bg{background:#21262d;border-radius:3px;height:5px;margin-bottom:8px}\n.bar{height:5px;border-radius:3px}\n.badge{font-size:10px;font-weight:700;padding:2px 8px;border-radius:10px;color:#fff}\n.footer{text-align:center;margin-top:24px;font-size:10px;color:#484f58;border-top:1px solid #21262d;padding-top:14px}\n</style></head>\n<body>\n<div class=\"header\">\n  <div class=\"header-left\">\n    <h1>📊 CHAMBALAND — Reporte de Monitoreo</h1>\n    <div class=\"sub\">Sistema de Monitoreo Inteligente · Zabbix + n8n + IA</div>\n  </div>\n  <div class=\"estado-badge\">${iconoGlobal} ${estadoGlobal}</div>\n</div>\n\n<div class=\"meta\">\n  <div class=\"meta-card\"><div class=\"meta-label\">🖥️ Host</div><div class=\"meta-val\">${hostNombre}</div></div>\n  <div class=\"meta-card\"><div class=\"meta-label\">📋 Categoría</div><div class=\"meta-val\">${etiqueta}</div></div>\n  <div class=\"meta-card\"><div class=\"meta-label\">📊 Items analizados</div><div class=\"meta-val\">${zabbixItems.length}</div></div>\n  <div class=\"meta-card\"><div class=\"meta-label\">🔴 Alertas críticas</div><div class=\"meta-val\" style=\"color:${criticos.length>0?'#f85149':'#3fb950'}\">${criticos.length}</div></div>\n  <div class=\"meta-card\"><div class=\"meta-label\">👤 Solicitado por</div><div class=\"meta-val\">${nombre}</div></div>\n  <div class=\"meta-card\"><div class=\"meta-label\">🕐 Generado</div><div class=\"meta-val\">${ahora}</div></div>\n</div>\n\n${alertasHtml}\n${gruposHtml}\n\n<div class=\"footer\">CHAMBALAND Platform · Zabbix + n8n + Google Gemini · ${ahora}</div>\n</body></html>`;\n\nreturn { html, tieneReporte:true, cantidadItems:zabbixItems.length, estadoGlobal, etiqueta, hostNombre, iconoGlobal, chatId };"
