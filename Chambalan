      "parameters": {
        "jsCode": "// CHAMBALAND — Preparar Query v14 — FIXED: filtro status+state, lastclock incluido\nconst sesion       = $node['🗂️ Gestor de Sesión'].json;\nconst hostId       = sesion.queryHostId || sesion.host?.id;\nconst esTodosHosts = !hostId || hostId === 'todos';\nconst metricaRaw   = sesion.metrica || 'general';\nconst bucket       = sesion.bucket   || null;\n\nconst labelMap = {\n  cpu:'CPU', ram:'RAM', memoria:'RAM', memory:'RAM', disco:'Disco',\n  storage:'Almacenamiento', red:'Red', network:'Red', os:'Sistema',\n  sistema:'Sistema', system:'Sistema', temperatura:'Temperatura',\n  salud:'Conectividad', health:'Conectividad', security:'Seguridad',\n  application:'Aplicaciones',\n};\n\nconst partes    = metricaRaw.toLowerCase().split('+').map(p=>p.trim()).filter(Boolean);\nconst esGeneral = partes.length===0 || partes.includes('general');\nconst etiqueta  = esGeneral\n  ? 'Estado General'\n  : partes.map(p=>labelMap[p]||p.charAt(0).toUpperCase()+p.slice(1)).join(' + ');\n\nconst params = {\n  output:      ['itemid','name','lastvalue','lastclock','units','value_type','key_','hostid','state','status'],\n  selectHosts: ['hostid','host','name'],\n  selectTags:  ['tag','value'],\n  filter: {\n    status: 0,   // 0 = enabled (excluye deshabilitados)\n    state:  0    // 0 = normal  (excluye \"not supported\")\n  },\n  monitored:   true,\n  sortfield:   'name',\n  sortorder:   'ASC',\n  limit:       500,\n};\n\nif (!esTodosHosts) params.hostids = [hostId];\n\nconst zabbixBody = JSON.stringify({\n  jsonrpc:'2.0', method:'item.get', params,\n  auth:'306be4bee609f26cae91f16592efdbcdc0bc2a6f94c95f80d7d7edf04341885a', id:1\n});\n\nconst metricasSeleccionadas = esGeneral ? ['general'] : partes;\nreturn { zabbixBody, esGeneral, hostId, esTodosHosts, etiqueta,\n         metricaRaw, bucket, metricasSeleccionadas };\n"
      },
