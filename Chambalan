      "parameters": {
        "jsCode": "// CHAMBALAND — Formatear Histórico v6 — Hora específica + timestamps\nconst sesion    = $node['🗂️ Gestor de Sesión'].json;\nconst prepData  = $node['📦 Armar Body Hist/Trend'].json;\nconst chatId    = sesion.chatId;\nconst bucket    = sesion.bucket || prepData.bucket || {};\nconst items     = prepData.items || [];\nconst metodo    = prepData.metodo;\nconst etiqueta  = prepData.etiqueta || 'General';\nconst hostNombre     = sesion.host?.nombre || 'Servidor';\nconst activeHostNombre = hostNombre; // para compatibilidad\nconst isCrossHost    = false; // cross-host bloqueado en Gestor — no llega aquí\nconst esTodos   = prepData.esTodos || sesion.host?.id === 'todos';\nconst histData  = ($json.result || []).filter(r => r.itemid !== '0');\n\nfunction escMd(s) { return String(s||'').replace(/[_*[\\]`]/g, c=>'\\\\'+c); }\n\n// === Si host no tiene la métrica ===\nif (prepData.noItemsFound || items.length === 0) {\n  return {\n    chatId,\n    mensaje: `❌ *${escMd(hostNombre)}* no tiene métricas de *${escMd(etiqueta)}* disponibles.\\n\\nEste host no recopila esa métrica en Zabbix.\\n\\n💡 _Prueba otra métrica o verifica los templates del host._`,\n    reply_markup: JSON.stringify({ inline_keyboard:[\n      [{ text:'🔄 Otra métrica', callback_data:'btn_volver_metricas' }],\n      [{ text:'🔙 Volver', callback_data:'btn_volver_acciones' }]\n    ]})\n  };\n}\n\nif (!histData.length) {\n  return {\n    chatId,\n    mensaje: `📈 *Histórico — ${escMd(etiqueta)}*\\n\\n❌ Sin datos para: *${bucket.label||'N/A'}*\\n\\n💡 _El host puede no haber estado activo en ese período._`,\n    reply_markup: JSON.stringify({ inline_keyboard:[\n      [{ text:'🔄 Otra métrica', callback_data:'btn_volver_metricas' }],\n      [{ text:'🔙 Volver', callback_data:'btn_volver_acciones' }]\n    ]})\n  };\n}\n\n// Mapa itemid → info del item\nconst itemMap = {};\nfor (const item of items) {\n  const hostName = item.hosts?.[0]?.name || hostNombre;\n  itemMap[item.itemid] = { ...item, hostName };\n}\n\nfunction fmtVal(v, u, key) {\n  const k = key||'';\n  if(u==='%') return v.toFixed(1)+'%';\n  if(u==='bps'||u==='Bps') { if(v>=1e9) return (v/1e9).toFixed(2)+' Gbps'; if(v>=1e6) return (v/1e6).toFixed(2)+' Mbps'; if(v>=1e3) return (v/1e3).toFixed(1)+' Kbps'; return v.toFixed(0)+' bps'; }\n  if(u==='B'||/memory|disk|vfs|storage/.test(k)) { if(v>=1073741824) return (v/1073741824).toFixed(2)+' GB'; if(v>=1048576) return (v/1048576).toFixed(1)+' MB'; return (v/1024).toFixed(0)+' KB'; }\n  if(u==='s') { if(v>=86400) return (v/86400).toFixed(1)+' días'; if(v>=3600) return (v/3600).toFixed(1)+' h'; if(v>=60) return (v/60).toFixed(0)+' min'; return v.toFixed(0)+' s'; }\n  if(u) return v.toFixed(2)+' '+u;\n  return v.toFixed(2);\n}\n\nfunction fmtTime(clock, full) {\n  return new Date(parseInt(clock)*1000).toLocaleString('es-CO', full\n    ? { timeZone:'America/Bogota', day:'2-digit', month:'2-digit', year:'2-digit', hour:'2-digit', minute:'2-digit' }\n    : { timeZone:'America/Bogota', hour:'2-digit', minute:'2-digit' });\n}\n\nfunction getStatusIcon(v, u, key) {\n  const k = key||'';\n  if(u!=='%') return '📊';\n  const esFree=/free|avail|idle/.test(k);\n  if(esFree) return v<10?'🔴':v<25?'🟡':'🟢';\n  return v>90?'🔴':v>75?'🟡':'🟢';\n}\n\nfunction getTrend(values) {\n  if (values.length<3) return '➡️';\n  const half=Math.max(1,Math.ceil(values.length/4));\n  const first=values.slice(0,half).reduce((a,b)=>a+b,0)/half;\n  const last=values.slice(-half).reduce((a,b)=>a+b,0)/half;\n  const diff=((last-first)/Math.max(first,0.001))*100;\n  return diff>8?'📈':diff<-8?'📉':'➡️';\n}\n\n// ¿Es consulta de hora específica?\nconst esEspecifico = bucket.tipo === 'especifico';\nconst timePico     = bucket.timePico || null;\n\nconst SKIP_NAMES = ['get data','discovery rule','snmp walk','zabbix agent','nvps','gathering','process'];\n// Sort: aggregate items (no \"#N:\" prefix) BEFORE per-core items\nconst relevantItems = items.filter(i => {\n  const nm = (i.name||'').toLowerCase();\n  return !SKIP_NAMES.some(s=>nm.includes(s));\n}).sort((a, b) => {\n  // Per-core items have \"#N: \" prefix (e.g. \"#10: CPU utilization\", \"#2: Free memory\")\n  const aCore = /^#\\d+[:\\s]/.test(a.name||'') ? 1 : 0;\n  const bCore = /^#\\d+[:\\s]/.test(b.name||'') ? 1 : 0;\n  if (aCore !== bCore) return aCore - bCore; // aggregates first\n  // Among same type, prefer items with recent lastclock\n  return parseInt(b.lastclock||0) - parseInt(a.lastclock||0);\n}).slice(0, 6); // Max 6 items — show aggregates, avoid per-core clutter\n\n// Agrupar histData por itemid\nconst byItem = {};\nfor (const row of histData) {\n  if (!byItem[row.itemid]) byItem[row.itemid] = [];\n  const v = parseFloat(metodo==='trend' ? row.value_avg : row.value);\n  if (!isNaN(v)) byItem[row.itemid].push({ clock: parseInt(row.clock), value: v });\n}\nfor (const iid of Object.keys(byItem)) byItem[iid].sort((a,b)=>a.clock-b.clock);\n\n// Renderizar un item según si es consulta específica o relativa\nfunction renderItem(item) {\n  const pts = byItem[item.itemid] || [];\n  if (!pts.length) return '';\n  const u = item.units || '';\n  const k = item.key_ || '';\n  const name = escMd(item.name.replace(/\\s*\\[.*?\\]/g,'').substring(0,42));\n  let s = `📌 *${name}*\\n`;\n\n  if (esEspecifico && timePico) {\n    // === CONSULTA DE HORA ESPECÍFICA: mostrar el valor más cercano al tiempo pedido ===\n    // Encontrar el punto más cercano a timePico\n    let closest = pts[0];\n    let minDiff = Math.abs(pts[0].clock - timePico);\n    for (const pt of pts) {\n      const diff = Math.abs(pt.clock - timePico);\n      if (diff < minDiff) { minDiff = diff; closest = pt; }\n    }\n\n    const icon = getStatusIcon(closest.value, u, k);\n    const timePicoStr = fmtTime(timePico, false);\n    const closestTimeStr = fmtTime(closest.clock, true);\n    const diffMin = Math.round(minDiff / 60);\n    const diffTxt = diffMin === 0 ? 'dato exacto' : `dato más cercano, ${diffMin} min de diferencia`;\n\n    s += `  ⏰ *A las ${timePicoStr}:* ${icon} *${fmtVal(closest.value, u, k)}*\\n`;\n    s += `  _(${closestTimeStr} — ${diffTxt})_\\n`;\n\n    // Contexto: 2 puntos antes y 2 después del más cercano\n    const idx = pts.indexOf(closest);\n    const ctxStart = Math.max(0, idx-2);\n    const ctxEnd   = Math.min(pts.length, idx+3);\n    const context  = pts.slice(ctxStart, ctxEnd);\n    if (context.length > 1) {\n      s += `  Contexto:\\n`;\n      for (const pt of context) {\n        const isTarget = pt === closest;\n        const icn = getStatusIcon(pt.value, u, k);\n        s += `  ${isTarget ? '👉' : '  '} ${fmtTime(pt.clock, true)} → ${icn} ${fmtVal(pt.value, u, k)}\\n`;\n      }\n    }\n\n  } else if (esEspecifico && !timePico) {\n    // === DÍA COMPLETO ESPECÍFICO: resumen del día ===\n    const vals = pts.map(p=>p.value);\n    const avg = vals.reduce((a,b)=>a+b,0)/vals.length;\n    const mn = Math.min(...vals);\n    const mx = Math.max(...vals);\n    const trend = getTrend(vals);\n\n    s += `  ${trend} Promedio del día: *${fmtVal(avg,u,k)}*\\n`;\n    s += `  📉 Mínimo: _${fmtVal(mn,u,k)}_ · 📈 Máximo: _${fmtVal(mx,u,k)}_\\n`;\n    // Primeros y últimos puntos del día\n    const muestra = pts.length<=6 ? pts : [...pts.slice(0,2), ...pts.slice(-3)];\n    for (const pt of muestra) s += `  🕐 ${fmtTime(pt.clock,true)} → ${fmtVal(pt.value,u,k)}\\n`;\n    if (pts.length > 6) s += `  _(${pts.length-5} muestras intermedias)_\\n`;\n\n  } else {\n    // === CONSULTA RELATIVA (\"hace 3 horas\", \"últimos 7 días\") ===\n    const vals = pts.map(p=>p.value);\n    const avg = vals.reduce((a,b)=>a+b,0)/vals.length;\n    const mn = Math.min(...vals);\n    const mx = Math.max(...vals);\n    const trend = getTrend(vals);\n\n    if (metodo === 'history') {\n      // Mostrar puntos con timestamps\n      const shown = pts.length <= 6 ? pts\n        : [pts[0], pts[Math.floor(pts.length/2)-1], pts[Math.floor(pts.length/2)], pts[pts.length-2], pts[pts.length-1]]\n            .filter((p,i,a)=>a.findIndex(x=>x.clock===p.clock)===i);\n      for (const pt of shown) {\n        const icn = getStatusIcon(pt.value, u, k);\n        s += `  🕐 ${fmtTime(pt.clock, pts.length>50)} → ${icn} *${fmtVal(pt.value,u,k)}*\\n`;\n      }\n      if (pts.length > shown.length) s += `  _(...${pts.length-shown.length} muestras intermedias)_\\n`;\n      s += `  ${trend} Prom: *${fmtVal(avg,u,k)}* | Min: _${fmtVal(mn,u,k)}_ | Max: _${fmtVal(mx,u,k)}_\\n`;\n    } else {\n      // Trend: agrupar por día para semanas/meses/año; solo stats para otras ventanas\n      const bucketTipo = (typeof bucket !== 'undefined' && bucket) ? bucket.tipo : '';\n      const groupByDay = ['semanas','meses','año'].includes(bucketTipo);\n      if (groupByDay && pts.length > 0) {\n        // Agrupar puntos por día Colombia (UTC-5)\n        const byDay = {};\n        for (const pt of pts) {\n          const d = new Date((pt.clock - 0) * 1000);\n          // Ajustar a Colombia UTC-5\n          const colD = new Date(d.getTime() - 5*3600*1000);\n          const dayKey = `${colD.getUTCFullYear()}-${String(colD.getUTCMonth()+1).padStart(2,'0')}-${String(colD.getUTCDate()).padStart(2,'0')}`;\n          if (!byDay[dayKey]) byDay[dayKey] = [];\n          byDay[dayKey].push(pt.value);\n        }\n        const dayKeys = Object.keys(byDay).sort();\n        s += `  ${trend} Prom global: *${fmtVal(avg,u,k)}* | 📉 _${fmtVal(mn,u,k)}_ | 📈 _${fmtVal(mx,u,k)}_\\n`;\n        for (const dk of dayKeys) {\n          const dVals = byDay[dk];\n          const dAvg  = dVals.reduce((a,b)=>a+b,0)/dVals.length;\n          const dMin  = Math.min(...dVals);\n          const dMax  = Math.max(...dVals);\n          // Formato legible: YYYY-MM-DD → DD/MM\n          const [dy, dm, dd] = dk.split('-');\n          const dayLabel = `${dd}/${dm}`;\n          const dTrend = dVals.length > 1\n            ? (dVals[dVals.length-1] > dVals[0] ? '📈' : dVals[dVals.length-1] < dVals[0] ? '📉' : '➡️')\n            : '➡️';\n          s += `  🗓️ *${dayLabel}* ${dTrend} P