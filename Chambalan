        "jsCode": "// ── Formatear Config SNMP v2 (Markdown simple) ───────────────\nconst prep     = $node['🔧 Preparar Lectura Config'].json;\nconst items    = $json.result || [];\nconst chatId   = prep.chatId;\nconst hostname = prep.hostname || 'Host';\nconst subtipo  = prep.configSubtipo || 'general';\nconst noHost   = prep.noHost || false;\n\n// Regular Markdown: only escape _ * ` [\nfunction escMd(s) {\n  return String(s||'').replace(/[_*`\\[]/g, '\\\\$&');\n}\nfunction formatUptime(val, key) {\n  if (!val || isNaN(parseFloat(val))) return String(val||'N/A');\n  const num = parseFloat(val);\n  // sysUpTime comes in centiseconds (hundredths of a second)\n  const secs = num > 86400000 ? num / 100 : num;\n  const d = Math.floor(secs / 86400);\n  const h = Math.floor((secs % 86400) / 3600);\n  const m = Math.floor((secs % 3600) / 60);\n  return `${d}d ${h}h ${m}min`;\n}\nfunction formatSpeed(mbps) {\n  if (!mbps || isNaN(parseFloat(mbps))) return '';\n  const n = parseFloat(mbps);\n  return n >= 1000 ? `${(n/1000).toFixed(0)} Gbps` : `${n} Mbps`;\n}\nfunction formatTraffic(bps) {\n  if (bps === null || bps === undefined || isNaN(parseFloat(bps))) return null;\n  const n = parseFloat(bps);\n  if (n >= 1e9)  return `${(n/1e9).toFixed(2)} Gbps`;\n  if (n >= 1e6)  return `${(n/1e6).toFixed(2)} Mbps`;\n  if (n >= 1000) return `${(n/1e3).toFixed(1)} Kbps`;\n  return `${n.toFixed(0)} bps`;\n}\nfunction tsToCol(ts) {\n  if (!ts || ts === '0') return 'N/A';\n  return new Date(parseInt(ts)*1000).toLocaleString('es-CO',{\n    timeZone:'America/Bogota',day:'2-digit',month:'2-digit',\n    hour:'2-digit',minute:'2-digit'\n  });\n}\n\nconst now = Math.floor(Date.now()/1000);\n// MAX_AGE relajado: 90 días. Items SNMP estáticos (sysName, OS) se actualizan poco.\n// Para items con lastclock=0 (nunca colectado), los incluimos igualmente si tienen lastvalue.\nconst MAX_AGE = 86400 * 90;\n\nif (noHost) {\n  const txt = `⚙️ *Configuración*\\n\\n⚠️ _No hay un host específico seleccionado. Selecciona un host primero._`;\n  const kb = { inline_keyboard:[[{text:'🔙 Volver',callback_data:'btn_volver_acciones'}]] };\n  return [{ json:{ mensaje:txt, chatId, reply_markup:JSON.stringify(kb) } }];\n}\n\n// ─── Categorize items ─────────────────────────────────────────\nconst ifaces = {};\nconst sistema = [];\nconst rutas   = [];\n\n// También acumular todos en 'todos' para la sección general\nconst todos = [];\n\nfor (const item of items) {\n  const key  = item.key_  || '';\n  const name = item.name  || '';\n  const lv   = item.lastvalue;\n\n  // Incluir items con lastvalue válido (incluye \"0\")\n  // Si lastvalue está vacío pero el item existe, aún lo mostramos en general\n  const hasValue = lv !== null && lv !== undefined && lv !== '';\n  if (!hasValue) continue;\n\n  // Filtro de antigüedad relajado\n  const clock = parseInt(item.lastclock || '0');\n  if (clock > 0 && (now - clock) > MAX_AGE) continue;\n\n  todos.push(item);\n\n  // ── Interfaces ──────────────────────────────────────────────\n  // Captura: ifXxx keys, net.if.*, \"Interface X\" en nombre\n  if (/\\bifoper|\\bifadmin|\\bifhigh|\\bifhcin|\\bifhcout|net\\.if\\.|\\bifalias|\\bifdescr|\\bifin|\\bifout|\\bifinoctets|\\bifoutoctets|interface[\\s_\\.]/i.test(key+' '+name)) {\n    const mName = name.match(/Interface\\s+([^\\s:,\\[]+)/i)\n                || name.match(/\\[([^\\]]+)\\]/)\n                || [null, key.replace(/^.*\\[|\\.\\d+$|\\].*$/g,'').substring(0,20) || 'iface'];\n    const ifKey = (mName[1]||'iface').replace(/^eth|^en|^lo/,'$&').substring(0,20);\n    if (!ifaces[ifKey]) ifaces[ifKey] = { name:ifKey, items:[] };\n    ifaces[ifKey].items.push(item);\n    continue;\n  }\n\n  // ── Sistema ─────────────────────────────────────────────────\n  // Captura: system.*, sys*, uptime, OS, memory, firmware, versión\n  if (/system\\.|\\bsysup|\\bsysname|\\bsysdescr|\\bsyscontact|\\bsyslocation|\\bsysoid|uptime|device[\\s.]name|firmware|softwar|\\bos\\b|\\bversion|\\bmemory\\b|free[\\s.]mem|swap|cpu\\b|load\\b|operating|processor/i.test(key+' '+name)) {\n    sistema.push(item);\n    continue;\n  }\n\n  // ── Rutas ────────────────────────────────────────────────────\n  if (/\\broute|\\broutin|inetcidr|bgp\\b|ospf\\b|isis\\b|rip\\b/i.test(key+' '+name)) {\n    rutas.push(item);\n    continue;\n  }\n}\n\nlet msg = '';\nconst ifList = Object.values(ifaces).sort((a,b)=>a.name.localeCompare(b.name));\n\n// ─── INTERFACES ───────────────────────────────────────────────\nif (subtipo === 'interfaces' || subtipo === 'general') {\n  if (ifList.length > 0) {\n    msg += `📡 *Interfaces — ${escMd(hostname)}*\\n\\n`;\n    for (const iface of ifList.slice(0, 20)) {\n      const si  = iface.items.find(i => /ifoper|oper.status/i.test(i.key_+i.name));\n      const ai  = iface.items.find(i => /ifadmin|admin.status/i.test(i.key_+i.name));\n      const spi = iface.items.find(i => /ifhigh|speed/i.test(i.key_+i.name));\n      const ini = iface.items.find(i => /ifhcin|\\.in\\[|bits.*rec|inbound/i.test(i.key_+i.name));\n      const oui = iface.items.find(i => /ifhcout|\\.out\\[|bits.*sent|outbound/i.test(i.key_+i.name));\n      const ali = iface.items.find(i => /alias|descr/i.test(i.key_));\n\n      const operVal  = si ? parseInt(si.lastvalue) : null;\n      const isUp     = operVal === 1;\n      const isDisabled = ai ? parseInt(ai.lastvalue) !== 1 : false;\n      const icon     = isDisabled ? '⛔' : (si ? (isUp ? '✅' : '❌') : '❓');\n      const statusTxt= isDisabled ? 'DISABLED' : (si ? (isUp ? 'UP' : 'DOWN') : '');\n\n      const speed   = spi ? formatSpeed(spi.lastvalue) : '';\n      const alias   = ali?.lastvalue || '';\n      const inTxt   = ini ? formatTraffic(ini.lastvalue) : null;\n      const outTxt  = oui ? formatTraffic(oui.lastvalue) : null;\n\n      let line = `${icon} *${escMd(iface.name)}*`;\n      if (statusTxt) line += ` — ${statusTxt}`;\n      if (speed)     line += ` — ${escMd(speed)}`;\n      msg += line + '\\n';\n      if (alias)          msg += `    _${escMd(alias)}_\\n`;\n      if (inTxt || outTxt) msg += `    ↓${escMd(inTxt||'?')} ↑${escMd(outTxt||'?')}\\n`;\n    }\n    if (ifList.length > 20) msg += `_... y ${ifList.length-20} interfaces más_\\n`;\n    msg += '\\n';\n  } else if (subtipo === 'interfaces') {\n    msg += `📡 *Interfaces — ${escMd(hostname)}*\\n\\n`;\n    msg += `_No se encontraron items de interfaces en Zabbix para este host._\\n`;\n    msg += `_El template SNMP puede no incluir monitoreo de interfaces._\\n\\n`;\n  }\n}\n\n// ─── SISTEMA ──────────────────────────────────────────────────\nif (subtipo === 'sistema' || subtipo === 'general') {\n  if (sistema.length > 0) {\n    msg += `💻 *Sistema — ${escMd(hostname)}*\\n\\n`;\n    sistema.sort((a,b) => {\n      const p = i => /uptime|sysname|name/i.test(i.key_+i.name) ? 0 : 1;\n      return p(a) - p(b);\n    });\n    for (const item of sistema.slice(0, 12)) {\n      const cleanName = item.name.replace(/\\s*\\[.*?\\]/g,'').trim();\n      let val = item.lastvalue || 'N/A';\n      if (/uptime/i.test(item.key_+item.name)) val = formatUptime(val, item.key_);\n      msg += `  • *${escMd(cleanName)}:* ${escMd(val)}\\n`;\n    }\n    msg += '\\n';\n  } else if (subtipo === 'sistema') {\n    msg += `💻 *Sistema — ${escMd(hostname)}*\\n\\n_No se encontraron datos de sistema._\\n\\n`;\n  }\n}\n\n// ─── RUTAS ────────────────────────────────────────────────────\nif (subtipo === 'rutas' || subtipo === 'general') {\n  if (rutas.length > 0) {\n    msg += `🗺️ *Rutas — ${escMd(hostname)}*\\n\\n`;\n    for (const r of rutas.slice(0, 10)) {\n      const cleanName = r.name.replace(/\\s*\\[.*?\\]/g,'').trim();\n      msg += `  • *${escMd(cleanName)}:* ${escMd(r.lastvalue)}\\n`;\n    }\n    msg += '\\n';\n  } else if (subtipo === 'rutas') {\n    msg += `🗺️ *Rutas — ${escMd(hostname)}*\\n\\n`;\n    msg += `_No se encontraron items de rutas en Zabbix._\\n`;\n    msg += `_Las tablas de rutas requieren templates SNMP avanzados o SSH (Fase 2)._\\n\\n`;\n  }\n}\n\n// ─── GENERAL: muestra todos los items cuando no hay categoría específica ──\nif (subtipo === 'general') {\n  if (todos.length > 0) {\n    msg = `📊 *General — ${escMd(hostname)}*\\n\\n`;\n    const shown = new Set();\n    // Primero: sistema\n    if (sistema.length) {\n      msg += `💻 *Sistema*\\n`;\n      for (const it of sistema.slice(0,8)) {\n        const cn = it.name.replace(/\\s*\\[.*?\\]/g,'').trim();\n        let val = it.lastvalue;\n        if (/uptime/i.test(it.key_+it.name)) val = formatUptime(val, it.key_);\n        msg += `  • *${escMd(cn.substring(0,30))}:* ${escMd(String(val).substring(0,50))}\\n`;\n        shown.add(it.itemid);\n      }\n      msg += '\\n';\n    }\n    // Interfaces\n    if (ifList.length) {\n      msg += `📡 *Interfaces* (${ifList.length})\\n`;\n      for (const iface of ifList.slice(0,5)) {\n        const si  = iface.items.find(i => /ifoper|oper.status/i.test(i.key_+i.name));\n        const isUp = si ? parseInt(si.lastvalue) === 1 : null;\n        const icon = isUp === null ? '❓' : (isUp ? '✅' : '❌');\n        msg += `  ${icon} *${escMd(iface.name)}*\\n`;\n        for (const it of iface.items) shown.add(it.itemid);\n      }\n      if (ifList.length > 5) msg += `  _...y ${ifList.length-5} interfaces más_\\n`;\n      msg += '\\n';\n    }\n    // Resto sin categorizar\n    const resto = todos.filter(it => !shown.has(it.itemid));\n    if (resto.length > 0) {\n      msg += `📋 *Otros items* (${resto.length})\\n`;\n      for (const it of resto.slice(0,8)) {\n        const cn = it.name.replace(/\\s*\\[.*?\\]/g,'').trim();\n        msg += `  • ${escMd(cn.substring(0,32))}: _${escMd(String(it.lastvalue).substring(0,30))}_\\n`;\n      }\n      if (resto.length > 8) msg += `  _...y ${resto.length-8} más_\\n`;\n    }\n  } else {\n    msg = `⚙️ *Configuración — ${escMd(hostname)}*\\n\\n`;\n    msg += `❌ _No se encontraron items activos en Zabbix._\\n\\n`;\n    msg += `• Verifica que el host esté accesible\\n`;\n    msg += `• Verifica que tenga templates asignados\\n`;\n    msg += `_Monitoring → Latest data en Zabbix para más detalles._`;\n  }\n}\n\n// ─── Fallback final ────────────────────────────────────────────\nif (!msg) {\n  if (todos.length > 0) {\n    msg = `⚙️ *Configuración — ${escMd(hostname)}*\\n\\n`;\n    msg += `⚠️ _No hay items en la sección \"${subtipo}\", pero el host tiene ${todos.length} items activos._\\n\\n`;\n    msg += `💡 Prueba con la sección *General* para ver todos los datos.`;\n  } else {\n    msg = `⚙️ *Configuración — ${escMd(hostname)}*\\n\\n`;\n    msg += `❌ _No se encontraron datos en Zabbix para este host._\\n`;\n    msg += `_Verifica en Monitoring → Latest data._`;\n  }\n}\n\n// Footer\nconst clocks = items.map(i=>parseInt(i.lastclock||0)).filter(v=>v>0);\nconst maxClock = clocks.length ? Math.max(...clocks) : 0;\nmsg += `\\n_${items.length} items en Zabbix${maxClock ? ' — actualizado: ' + tsToCol(maxClock) : ''}_`;\n\nconst keyboard = { inline_keyboard: [\n  [{ text:'📡 Interfaces',  callback_data:'btn_cfg_interfaces' },\n   { text:'💻 Sistema',     callback_data:'btn_cfg_sistema' }],\n  [{ text:'🗺️ Rutas',      callback_data:'btn_cfg_rutas' },\n   { text:'📊 General',     callback_data:'btn_cfg_general' }],\n  [{ text:'🔄 Actualizar',  callback_data:`btn_cfg_${subtipo}` },\n   { text:'🔙 Volver',      callback_data:'btn_volver_acciones' }]\n]};\n\nreturn [{ json: { mensaje: msg, chatId, reply_markup: JSON.stringify(keyboard) } }];\n"
