        "jsCode": "// CHAMBALAND — Generar Resumen Texto v13 — Clasificación por key_ + tags\nconst sesionData   = $node['🗂️ Gestor de Sesión'].json;\nconst queryData    = $node['Preparar Query Texto'].json;\nconst chatId       = sesionData.chatId;\nconst etiqueta     = queryData?.etiqueta     || 'General';\nconst esTodosHosts = queryData?.esTodosHosts || false;\nconst hostNombre   = esTodosHosts ? 'Todos los hosts' : (sesionData.host?.nombre || 'Servidor');\nconst partes       = (sesionData.metrica||'general').toLowerCase().split('+').map(p=>p.trim()).filter(Boolean);\nconst esGeneral    = partes.length===0 || partes.includes('general');\n\nconst ahora = new Date().toLocaleString('es-CO',{timeZone:'America/Bogota',dateStyle:'short',timeStyle:'short'});\nfunction esc(s){ return String(s||'').replace(/[_*[\\]`]/g,c=>'\\\\'+c); }\n\n// ── Clasificar item por componente usando key_ primero, tags como fallback ──\nfunction clasificarItem(item) {\n  const k  = (item.key_||'').toLowerCase();\n  const nm = (item.name||'').toLowerCase();\n  \n  // Por key_ (más confiable que tags)\n  if (/^system\\.cpu|^proc\\.cpu|cpu\\.util|^perf_counter.*cpu/i.test(k)) return 'cpu';\n  if (/^vm\\.memory|^system\\.swap|memory\\.|mem\\./i.test(k))              return 'memory';\n  if (/^vfs\\.fs|^system\\.sw\\.packages\\.(number|get)|disk\\./i.test(k))  return 'storage';\n  if (/^net\\.if|^icmp|^net\\.tcp|^net\\.udp|^zabbix\\.proxy/i.test(k))    return 'network';\n  if (/^system\\.hostname|^system\\.uname|^system\\.uptime|^system\\.localtime|^kernel\\.|^system\\.boottime/i.test(k)) return 'system';\n  if (/^system\\.cpu\\.temp|^sensor|temperature/i.test(k))                return 'temperature';\n  if (/^web\\.|^net\\.tcp\\.service\\[http|^proc\\.num/i.test(k))            return 'application';\n  if (/^zabbix\\.|^agent\\./i.test(k))                                    return 'zabbix_internal';\n  \n  // Por tags como fallback\n  const tagComp = (item.tags||[]).find(t=>t.tag==='component')?.value;\n  if (tagComp) return tagComp;\n  \n  // Por nombre como último recurso\n  if (/cpu|processor|procesador/i.test(nm))  return 'cpu';\n  if (/memory|memoria|ram|swap/i.test(nm))   return 'memory';\n  if (/disk|disco|storage|filesystem|vfs/i.test(nm)) return 'storage';\n  if (/network|red|interface|traffic|icmp/i.test(nm)) return 'network';\n  if (/uptime|hostname|system|sistema|os\\b/i.test(nm)) return 'system';\n  if (/temperature|temperatura|thermal/i.test(nm)) return 'temperature';\n  \n  return 'otros';\n}\n\n// ── Mapeo métrica solicitada → componentes ──\nconst metricaToComps = {\n  cpu:['cpu'], ram:['memory'], memoria:['memory'], disco:['storage'],\n  red:['network'], os:['system'], sistema:['system'],\n  temperatura:['temperature'], health:['network'], salud:['network'],\n  security:['security'], application:['application'],\n};\n\n// ── Filtrar items inútiles ──\nconst SKIP_KEYS = ['zabbix agent availability','zabbix agent ping','preprocessing',\n                   'get snmp','snmp walk','discovery','nvps','gathering'];\nfunction isUseful(item) {\n  // FIX v14: descartar items nunca colectados (lastclock=0 = dato falso)\n  if (parseInt(item.lastclock||'0') === 0) return false;\n  const v = String(item.lastvalue||'').trim();\n  if (!v || v==='null' || v==='' || v==='-1') return false;\n  if (v.startsWith('{')||v.startsWith('[')) return false;\n  const nm = (item.name||'').toLowerCase();\n  if (SKIP_KEYS.some(k=>nm.includes(k))) return false;\n  const comp = clasificarItem(item);\n  if (comp === 'zabbix_internal') return false;\n  return true;\n}\n\n// ── Formatear valor con unidades ──\nfunction fmtVal(item) {\n  const raw = String(item.lastvalue||'').trim();\n  const u   = (item.units||'').trim();\n  const k   = (item.key_||'').toLowerCase();\n  const nm  = (item.name||'').toLowerCase();\n  const v   = parseFloat(raw);\n\n  if (isNaN(v)) {\n    if (!raw || raw.length > 80) return null;\n    return { txt: raw.substring(0,50), crit:false, warn:false };\n  }\n\n  // Porcentaje\n  if (u==='%') {\n    const isFree = /free|avail|idle|pfree/.test(k+nm);\n    const crit   = isFree ? v<5  : v>95;\n    const warn   = isFree ? v<15 : v>80;\n    const icon   = crit?'🔴':warn?'🟡':'🟢';\n    return { txt:`${icon} ${v.toFixed(1)}%`, crit, warn };\n  }\n  // Bytes\n  if (u==='B' || /vm\\.memory|vfs\\.fs|disk/.test(k)) {\n    if (v===0) return null; // no recolectado aún\n    const isFree = /free|avail/.test(k+nm);\n    let d;\n    if      (v>=1073741824) d=(v/1073741824).toFixed(2)+' GB';\n    else if (v>=1048576)    d=(v/1048576).toFixed(1)+' MB';\n    else if (v>=1024)       d=(v/1024).toFixed(0)+' KB';\n    else                    d=v.toFixed(0)+' B';\n    const icon = isFree?(v<512*1048576?'🔴':v<2*1073741824?'🟡':'🟢'):'📊';\n    return { txt:`${icon} ${d}`, crit:isFree&&v<512*1048576, warn:isFree&&v<2*1073741824 };\n  }\n  // bps\n  if (u==='bps'||u==='Bps') {\n    let d;\n    if(v>=1e9) d=(v/1e9).toFixed(2)+' Gbps';\n    else if(v>=1e6) d=(v/1e6).toFixed(2)+' Mbps';\n    else if(v>=1e3) d=(v/1e3).toFixed(1)+' Kbps';\n    else d=v.toFixed(0)+' bps';\n    return { txt:`🔵 ${d}`, crit:false, warn:false };\n  }\n  // Tiempo\n  if (u==='s'||u==='uptime'||/uptime|boottime/.test(k)) {\n    let d;\n    if(v>=86400) d=(v/86400).toFixed(1)+' días';\n    else if(v>=3600) d=(v/3600).toFixed(1)+' h';\n    else if(v>=60) d=(v/60).toFixed(0)+' min';\n    else d=v.toFixed(0)+' s';\n    return { txt:`⏱️ ${d}`, crit:false, warn:false };\n  }\n  // Número 0 sin unidad = probablemente no recolectado\n  if (v===0 && !u) return null;\n  const display = u ? `${v.toFixed(2)} ${u}` : (Number.isInteger(v)?`${v}`:`${v.toFixed(3)}`);\n  return { txt:`📊 ${display}`, crit:false, warn:false };\n}\n\nconst compOrder = ['cpu','memory','storage','network','system','temperature','security','application','health','otros'];\nconst compIcon  = {cpu:'🖥️',memory:'🧠',storage:'💾',network:'🌐',system:'⚙️',temperature:'🌡️',security:'🔐',application:'📦',health:'💚',otros:'📊'};\nconst compLabel = {cpu:'CPU',memory:'RAM / Memoria',storage:'Disco',network:'Red',system:'Sistema',temperature:'Temperatura',security:'Seguridad',application:'Aplicaciones',health:'Conectividad',otros:'Otros'};\n\nfunction renderItems(items, max=12) {\n  const valid = [];\n  for (const item of items) {\n    const r = fmtVal(item);\n    if (r) valid.push({item,r});\n  }\n  if (!valid.length) return { txt:'  _Sin datos disponibles_\\n', crits:0, warns:0 };\n  let txt='', crits=0, warns=0;\n  for (const {item,r} of valid.slice(0,max)) {\n    const nm = esc(item.name.replace(/\\s*\\[.*?\\]/g,'').replace(/^(FS|VM|Net):\\s*/i,'').substring(0,45));\n    txt += `  • ${nm}: *${esc(r.txt)}*\\n`;\n    if (r.crit) crits++;\n    if (r.warn) warns++;\n  }\n  if (valid.length>max) txt+=`  _...y ${valid.length-max} métricas más_\\n`;\n  return {txt, crits, warns};\n}\n\nfunction renderGrupos(itemList) {\n  // Clasificar y agrupar todos los items\n  const grupos = {};\n  for (const item of itemList) {\n    const comp = clasificarItem(item);\n    if (!grupos[comp]) grupos[comp]=[];\n    grupos[comp].push(item);\n  }\n  const keys = [...compOrder.filter(c=>grupos[c]), ...Object.keys(grupos).filter(c=>!compOrder.includes(c))];\n  let txt='', totalCrits=0, totalWarns=0;\n  for (const comp of keys) {\n    const {txt:t,crits,warns} = renderItems(grupos[comp]);\n    if (t.includes('Sin datos')) continue;\n    txt += `${compIcon[comp]||'📊'} *${compLabel[comp]||comp}*\\n${t}\\n`;\n    totalCrits+=crits; totalWarns+=warns;\n  }\n  return { txt: txt||'_Sin datos disponibles_\\n', crits:totalCrits, warns:totalWarns };\n}\n\nfunction renderMetrica(metrica, itemList) {\n  const comps = metricaToComps[metrica] || [metrica];\n  // Filtrar por clasificación\n  const filtrados = itemList.filter(i => comps.includes(clasificarItem(i)));\n  const icon  = compIcon[comps[0]]||'📊';\n  const label = compLabel[comps[0]]||metrica.toUpperCase();\n  const {txt,crits,warns} = renderItems(filtrados);\n  return { txt:`${icon} *${label}*\\n${txt}\\n`, crits, warns };\n}\n\n// Filtrar todos los items\nconst allItems = ($json.result||[]).filter(isUseful);\n\nif (!allItems.length) {\n  return {\n    chatId,\n    mensaje:`❌ No encontré métricas para *${esc(hostNombre)}*\\n\\n`+\n      `*${esc(etiqueta)}*\\n\\n`+\n      `Posibles causas:\\n`+\n      `• Los items aún no han recolectado datos (espera 5-10 min)\\n`+\n      `• El agente Zabbix no está activo\\n`+\n      `• El template no genera items para esta métrica`,\n    reply_markup: JSON.stringify({inline_keyboard:[\n      [{text:'🔄 Intentar de nuevo',callback_data:'btn_volver_metricas'}],\n      [{text:'🔙 Volver',callback_data:'btn_volver_acciones'}]\n    ]})\n  };\n}\n\nconst SEP='━━━━━━━━━━━━━━━━━━━━━━━━━━━━\\n';\nlet txt='', totalCrits=0, totalWarns=0;\n\nif (esTodosHosts) {\n  // Agrupar por host\n  const porHost={};\n  for (const item of allItems) {\n    const hName = item.hosts?.[0]?.name || `Host ${item.hostid}`;\n    if (!porHost[hName]) porHost[hName]=[];\n    porHost[hName].push(item);\n  }\n  if (!Object.keys(porHost).length) {\n    return { chatId, mensaje:`❌ Sin datos para todos los hosts`, reply_markup:JSON.stringify({inline_keyboard:[[{text:'🔙 Volver',callback_data:'btn_volver_acciones'}]]}) };\n  }\n  txt=`📊 *Todos los hosts — ${esc(etiqueta)}*\\n🕐 ${ahora}\\n${SEP}`;\n  for (const [hName,hItems] of Object.entries(porHost)) {\n    txt+=`🖥️ *${esc(hName)}*\\n`;\n    let res;\n    if (esGeneral) {\n      res = renderGrupos(hItems);\n    } else {\n      res = {txt:'',crits:0,warns:0};\n      for (const m of partes) {\n        const mr = renderMetrica(m, hItems);\n        res.txt+=mr.txt; res.crits+=mr.crits; res.warns+=mr.warns;\n      }\n    }\n    txt+=res.txt; totalCrits+=res.crits; totalWarns+=res.warns;\n    txt+='─ ─ ─ ─ ─ ─ ─ ─ ─ ─\\n\\n';\n  }\n} else {\n  let res;\n  if (esGeneral) {\n    res = renderGrupos(allItems);\n  } else {\n    res = {txt:'',crits:0,warns:0};\n    for (const m of partes) {\n      const mr = renderMetrica(m, allItems);\n      res.txt+=mr.txt; res.crits+=mr.crits; res.warns+=mr.warns;\n    }\n  }\n  totalCrits=res.crits; totalWarns=res.warns;\n  const estado = totalCrits>0?'🔴 Problemas críticos':totalWarns>0?'🟡 Advertencias':'🟢 Todo en orden';\n  txt=`📊 *${esc(hostNombre)} — ${esc(etiqueta)}*\\n🕐 ${ahora}\\n${SEP}${estado}\\n`;\n  if (totalCrits>0) txt+=`⚠️ ${totalCrits} críticos\\n`;\n  txt+=SEP+'\\n'+res.txt;\n}\n\ntxt+=SEP+'_💡 Escribe, ej: \"CPU hace 3 horas\", \"RAM de ayer\"_';\n\nconst REPLY=JSON.stringify({inline_keyboard:[\n  [{text:'📄 PDF Completo',callback_data:'btn_pdf'}],\n  [{text:'🔄 Otra métrica',callback_data:'btn_volver_metricas'},{text:'🔙 Volver',callback_data:'btn_volver_acciones'}]\n]});\nconst MAX=4000;\nif (txt.length<=MAX) return {chatId,mensaje:txt,reply_markup:REPLY};\n\nconst chunks=[];\nlet rem=txt;\nwhile(rem.length>MAX){\n  let cut=rem.lastIndexOf('\\n',MAX);\n  if(cut<=200) cut=MAX;\n  chunks.push(rem.substring(0,cut));\n  rem=rem.substring(cut).trimStart();\n}\nif(rem.trim()) chunks.push(rem);\nreturn chunks.map((chunk,i)=>({json:{\n  chatId,\n  mensaje:chunk+(i<chunks.length-1?`\\n_📄 Parte ${i+1}/${chunks.length}_`:''),\n  reply_markup:i===chunks.length-1?REPLY:undefined\n}}));\n"
