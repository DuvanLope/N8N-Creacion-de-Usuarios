        "jsCode": "// CHAMBALAND — Formatear Comparación v2 — Multi-host\nconst prep     = $node['📦 Armar Body Comp'].json;\nconst chatId   = prep.chatId;\nconst hosts    = prep.hosts || [];\nconst items    = prep.items || [];\nconst bucket   = prep.bucket || {};\nconst etiqueta = prep.etiqueta || 'General';\nconst metodo   = prep.metodo;\nconst histData = ($json.result || []).filter(r => r.itemid !== '0');\n\n// Lookup de ítems por itemid → acceder a lastvalue como FALLBACK para history.get\n// Esto resuelve: history.get history=0 (float) NO devuelve ítems uint64 (Total memory, etc.)\n// lastvalue viene directamente del agente Zabbix sin importar el value_type\nconst itemById = Object.fromEntries(items.map(it => [String(it.itemid), it]));\n\nfunction escMd(s) { return String(s||'').replace(/[_*[\\]`]/g, c=>'\\\\'+c); }\n\nif (!items.length) {\n  const sugerencia = prep.useNameSearch\n    ? `\\n💡 _Intenta: \"compara RAM de ${hosts.map(h=>h.nombre.split(' ')[0]).join(' vs ')}\" o \"qué items son comparables\"_`\n    : '';\n  return { chatId,\n    mensaje: `❌ Sin ítems numéricos para *${escMd(etiqueta)}* en los hosts seleccionados.${sugerencia}\\n_Verifica que la métrica exista en Zabbix._`,\n    reply_markup: JSON.stringify({ inline_keyboard:[\n      [{ text:'📋 Ver items comparables', callback_data:'btn_volver_metricas' }],\n      [{ text:'🔙 Volver', callback_data:'btn_volver_acciones' }]\n    ]})\n  };\n}\n// Si no hay histData, verificar si podemos usar lastvalue\n// (ítems uint64 como \"Total memory\" no aparecen en history.get float)\nconst itemsWithLastVal = items.filter(it =>\n  it.lastvalue !== '' && it.lastvalue !== null && it.lastvalue !== undefined\n  && !isNaN(parseFloat(it.lastvalue))\n);\nif (!histData.length && !itemsWithLastVal.length) {\n  return { chatId,\n    mensaje: `⚠️ Se encontraron ítems para *${escMd(etiqueta)}* pero sin datos en el período seleccionado.\\n_Prueba con un período más largo (ej: \"de los últimos 7 días\")._`,\n    reply_markup: JSON.stringify({ inline_keyboard:[\n      [{ text:'📋 Ver items comparables', callback_data:'btn_volver_metricas' }],\n      [{ text:'🔙 Volver', callback_data:'btn_volver_acciones' }]\n    ]})\n  };\n}\n// Continuar aunque histData esté vacío — stats() usará lastvalue como fallback\n\nfunction fmtVal(v, u, key) {\n  const k = key||'';\n  if(u==='%') return v.toFixed(1)+'%';\n  if(u==='bps'||u==='Bps') {\n    if(v>=1e9) return (v/1e9).toFixed(2)+' Gbps';\n    if(v>=1e6) return (v/1e6).toFixed(2)+' Mbps';\n    if(v>=1e3) return (v/1e3).toFixed(1)+' Kbps';\n    return v.toFixed(0)+' bps';\n  }\n  if(u==='B'||/memory|disk|vfs|storage/.test(k)) {\n    if(v>=1073741824) return (v/1073741824).toFixed(2)+' GB';\n    if(v>=1048576)    return (v/1048576).toFixed(1)+' MB';\n    return (v/1024).toFixed(0)+' KB';\n  }\n  if(u==='s') {\n    if(v>=86400) return (v/86400).toFixed(1)+' días';\n    if(v>=3600)  return (v/3600).toFixed(1)+' h';\n    if(v>=60)    return (v/60).toFixed(0)+' min';\n    return v.toFixed(0)+' s';\n  }\n  if(u) return v.toFixed(2)+' '+u;\n  return v.toFixed(2);\n}\n\n// Historial por itemid — soporta history (value) y trend (value_avg/min/max)\nconst histByItem = {};\nfor (const pt of histData) {\n  const isTrend = pt.value_avg !== undefined;\n  const avg = parseFloat(isTrend ? pt.value_avg : pt.value);\n  if (isNaN(avg)) continue;\n  if (!histByItem[pt.itemid]) histByItem[pt.itemid] = { vals:[], realMin:Infinity, realMax:-Infinity };\n  const d = histByItem[pt.itemid];\n  d.vals.push(avg);\n  const lo = isTrend ? parseFloat(pt.value_min)||avg : avg;\n  const hi = isTrend ? parseFloat(pt.value_max)||avg : avg;\n  d.realMin = Math.min(d.realMin, lo);\n  d.realMax = Math.max(d.realMax, hi);\n}\n\nfunction stats(itemid) {\n  const d = histByItem[String(itemid)];\n  if (d && d.vals.length > 0) {\n    const avg = d.vals.reduce((a,b)=>a+b,0) / d.vals.length;\n    return { avg,\n      min: d.realMin !== Infinity  ? d.realMin : avg,\n      max: d.realMax !== -Infinity ? d.realMax : avg,\n      n: d.vals.length, isLastValue: false };\n  }\n  // ── FALLBACK: usar lastvalue de item.get ──────────────────────────────────\n  // history.get con history=0 solo retorna floats. Los ítems uint64 (Total memory,\n  // interfaces en bps, uptime...) no aparecen en histByItem pero SÍ tienen lastvalue.\n  const it = itemById[String(itemid)];\n  if (it && it.lastvalue !== '' && it.lastvalue !== null && it.lastvalue !== undefined) {\n    const lv = parseFloat(it.lastvalue);\n    if (!isNaN(lv)) return { avg: lv, min: lv, max: lv, n: 1, isLastValue: true };\n  }\n  return null;\n}\n\n// Agrupar items por nombre limpio + host\n// metricMap[cleanName] = { units, key_, byHost: { hostid: itemid } }\n// Normalizar: eliminar [interfaz], prefijos #N: (por-core CPU), sufijos numéricos\nconst metricMap = {};\nfor (const it of items) {\n  let cleanName = it.name\n    .replace(/^#\\d+:\\s*/,'')        // Strip \"#10: \" prefix (per-core items)\n    .replace(/\\s*\\[.*?\\]/g,'')      // Strip \"[iface]\" suffixes\n    .replace(/\\s*\\(\\d+\\)$/,'')     // Strip trailing \"(N)\" numbers\n    .trim();\n  if (!metricMap[cleanName]) metricMap[cleanName] = { units: it.units||'', key_: it.key_||'', byHost:{} };\n  // Si ya hay un itemid para este host+cleanName, preferir el que tenga datos más recientes\n  if (!metricMap[cleanName].byHost[it.hostid]) {\n    metricMap[cleanName].byHost[it.hostid] = it.itemid;\n  }\n}\n\n// Solo métricas presentes en AL MENOS 2 hosts, ordenadas por cobertura↓ nombre↑\nconst hostIds = hosts.map(h => h.id);\nconst sortedMetrics = Object.entries(metricMap)\n  .map(([name, md]) => ({\n    name,\n    units: md.units, key_: md.key_, byHost: md.byHost,\n    coverage: hostIds.filter(id => md.byHost[id]).length\n  }))\n  .filter(m => m.coverage >= 2)\n  .sort((a,b) => b.coverage - a.coverage || a.name.localeCompare(b.name))\n  .slice(0, 25);   // Hasta 25 métricas comparables\n\nconst SEP = '━━━━━━━━━━━━━━━━━━━━━━━━━━━━\\n';\n// Mostrar rango real del bucket en lugar de la hora actual\nlet ahora;\nif (bucket.timeFrom && bucket.timeTill) {\n  const _fmtC = (ts) => new Date(ts * 1000).toLocaleString('es-CO', {\n    timeZone:'America/Bogota', day:'2-digit', month:'2-digit', year:'2-digit',\n    hour:'2-digit', minute:'2-digit'\n  });\n  ahora = `${_fmtC(bucket.timeFrom)} → ${_fmtC(bucket.timeTill)}`;\n} else {\n  ahora = new Date().toLocaleString('es-CO',{timeZone:'America/Bogota',dateStyle:'short',timeStyle:'short'});\n}\n\n// Tendencia: compara primer cuartil vs último cuartil de la serie temporal\nfunction getTrend(vals) {\n  if (!vals || vals.length < 4) return '➡️';\n  const q = Math.max(1, Math.floor(vals.length / 4));\n  const first = vals.slice(0, q).reduce((a,b)=>a+b,0) / q;\n  const last  = vals.slice(-q).reduce((a,b)=>a+b,0) / q;\n  const diff  = first > 0 ? ((last - first) / first) * 100 : 0;\n  return diff > 8 ? '📈' : diff < -8 ? '📉' : '➡️';\n}\nconst hostLabels = hosts.map(h => escMd(h.nombre.substring(0,13)));\n\nlet txt = `🔀 *Comparación — ${escMd(etiqueta)}*\\n`;\ntxt += `⏱️ *${bucket.label||'N/A'}*  🕐 ${ahora}\\n${SEP}\\n`;\ntxt += `🖥️ ${hostLabels.join(' ←→ ')}\\n${SEP}\\n`;\n\nlet totalWins = Object.fromEntries(hosts.map(h=>[h.id, 0]));\n\nfor (const m of sortedMetrics) {\n  const { name, units:u, key_:k, byHost, coverage } = m;\n  const coverageStr = coverage === hosts.length ? '' : ` _(${coverage}/${hosts.length} hosts)_`;\n  let anyLastValue = false; // se setea en el inner loop; usarlo DESPUÉS del loop\n\n  // Calcular stats por host\n  const perHost = hosts.map(h => {\n    const iid = byHost[h.id];\n    return { h, s: iid ? stats(iid) : null };\n  });\n\n  const withData = perHost.filter(ph => ph.s);\n  if (withData.length < 2) continue;\n\n  const lowerBetter = /utilization|usage|load|error|loss|latency/i.test(name) || u==='%';\n  // Ganador entre hosts que SÍ tienen el dato\n  let bestIdx = null, bestVal = null;\n  for (let i=0; i<perHost.length; i++) {\n    if (!perHost[i].s) continue;\n    const v = perHost[i].s.avg;\n    if (bestVal===null || (lowerBetter ? v < bestVal : v > bestVal)) {\n      bestVal = v; bestIdx = i;\n    }\n  }\n  if (bestIdx !== null) totalWins[hosts[bestIdx].id]++;\n\n  // Calcular diferencia % entre mejor y peor (entre los que tienen dato)\n  const vals = withData.map(ph=>ph.s.avg);\n  const lo = Math.min(...vals), hi = Math.max(...vals);\n  const diffPct = hi > 0 ? ((hi-lo)/hi*100).toFixed(1) : '0.0';\n  const diffStr = parseFloat(diffPct) > 0.5 ? ` _(Δ ${diffPct}%)_` : ' _≈ igual_';\n\n\n  txt += `📌 *${escMd(name.substring(0,36))}*${coverageStr}${diffStr}\\n`;\n\n  for (let i=0; i<perHost.length; i++) {\n    const { h, s } = perHost[i];\n    const label = escMd(h.nombre.substring(0,13));\n    if (s?.isLastValue) anyLastValue = true;\n    if (!s) {\n      txt += `  ${label}: _⚠️ no disponible_\\n`;\n    } else {\n      const medal  = i === bestIdx ? ' 🏆' : '';\n      const _iid   = items.find(it => it.hostid === h.id && it.name.replace(/\\s*\\[.*?\\]/g,'').trim() === name)?.itemid;\n      const _trend = getTrend((histByItem[String(_iid)] || {}).vals || []);\n      txt += `  ${label}: *${fmtVal(s.avg,u,k)}*${medal} ${_trend}  _[${fmtVal(s.min,u,k)}–${fmtVal(s.max,u,k)}]_${s.isLastValue?' _(actual)_':''}\\n`;\n    }\n  }\n  if (anyLastValue) txt += `  _\\u26a0\\ufe0f Valor actual como referencia (sin hist. en per\\u00EDodo)_\\n`;\n  txt += '\\n';\n}\n\n// Items que NINGÚN par de hosts comparte\nconst soloUnHost = Object.entries(metricMap).filter(([,md])=>\n  hostIds.filter(id=>md.byHost[id]).length === 1\n);\nif (soloUnHost.length) {\n  txt += `_No comparables (solo en 1 host): `;\n  txt += soloUnHost.slice(0,5).map(([n])=>escMd(n.substring(0,22))).join(', ');\n  if (soloUnHost.length>5) txt += ` y ${soloUnHost.length-5} más`;\n  txt += '_\\n';\n}\n\n// Veredicto global\nconst winEntries = Object.entries(totalWins).sort((a,b)=>b[1]-a[1]);\nconst topWinner = winEntries[0];\nconst topHost = hosts.find(h=>h.id===topWinner[0]);\nconst totalM = sortedMetrics.length;\ntxt += `\\n${SEP}`;\nif (topWinner[1] > 0 && topHost) {\n  txt += `🥇 *${escMd(topHost.nombre)}* gana en ${topWinner[1]}/${totalM} métrica${totalM!==1?'s':''}\\n`;\n} else {\n  txt += `_Sin diferencias significativas entre los hosts_\\n`;\n}\n\nreturn {\n  chatId,\n  mensaje: txt,\n  reply_markup: JSON.stringify({ inline_keyboard:[\n    [{ text:'📋 Ver items comparables', callback_data:'btn_volver_metricas' }],\n    [{ text:'🔄 Otra métrica', callback_data:'btn_volver_metricas' },\n     { text:'🔙 Volver',       callback_data:'btn_volver_acciones' }]\n  ]})\n};\n"
