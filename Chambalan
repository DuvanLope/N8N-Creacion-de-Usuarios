        "jsCode": "// Determinar OS tipo e IP para SSH desde respuesta Zabbix\nconst prev  = $input.first().json;  // respuesta HTTP de Zabbix API\n\n// Los metadatos (chatId, sshTexto, hostname) vienen del nodo PREPARAR\n// porque el HTTP Request node reemplaza el item con la respuesta de la API\nconst prep = $('🔧 Preparar Host Info SSH').first().json;\n\n// Si el nodo preparar ya señaló \"sin host\", pasar el error directo\nif (prep._noHost) return [{ json: prep }];\n\nconst chatId   = prep.chatId   || prev.chatId;\nconst sshTexto = prep.sshTexto || prev.sshTexto || '';\nconst result   = prev.result || [];\n\nif (!result.length) {\n  // Diagnosticar: mostrar qué devolvió la API de Zabbix\n  const zabbixErr = prev.error ? ` Zabbix error: ${JSON.stringify(prev.error)}` : '';\n  const zabbixRaw = JSON.stringify(prev).substring(0, 200);\n  const hostIdUsed = prep.hostId || 'undefined';\n  return [{ json: {\n    _error: true, chatId, sshTexto,\n    msg: `❌ *Host no encontrado en Zabbix* (ID: ${hostIdUsed})\\n\\n_Respuesta API:_ \\`${zabbixRaw}\\`\\n${zabbixErr}\\n\\nVerifica que el host esté activo y el token tenga permisos.`\n  }}];\n}\n\nconst host     = result[0];\nconst hostname = host.name || host.host;\nconst templates = (host.parentTemplates || []).map(t => t.name);\nconst tplLower  = templates.join(' ').toLowerCase();\n\n// ── Detectar OS desde templates ──────────────────────────────\nlet osType = 'unknown';\nif (/mikrotik|routeros|chr|cloud.hosted.router/i.test(tplLower))               osType = 'mikrotik';\nelse if (/linux|ubuntu|debian|centos|rhel|suse|alpine|redhat/i.test(tplLower)) osType = 'linux';\nelse if (/windows|winrm|win32/i.test(tplLower))                                osType = 'windows';\nelse if (/fortinet|fortigate/i.test(tplLower))                                 osType = 'fortinet';\nelse if (/cisco|ios\\b|nx.?os/i.test(tplLower))                                 osType = 'cisco';\n\n// 2do intento: templates de aplicaciones que CORREN sobre Linux\n// Apache, Nginx, MySQL, PostgreSQL, Docker, Redis, MongoDB, Zabbix server/agent\nif (osType === 'unknown') {\n  if (/apache|nginx|mysql|mariadb|postgresql|mongodb|redis|memcached|docker|kubernetes|haproxy|php|zabbix\\s*(server|agent|proxy)|by\\s+zabbix\\s+agent/i.test(tplLower)) {\n    osType = 'linux';  // Estos servicios casi siempre corren en Linux\n  }\n}\n\n// 3er intento: nombre del host o descripción\nif (osType === 'unknown') {\n  const hint = (hostname + ' ' + (host.description || '')).toLowerCase();\n  if (/mikrotik|routeros|rb\\d{3}|chr/i.test(hint))         osType = 'mikrotik';\n  else if (/linux|ubuntu|debian|centos|server|srv/i.test(hint)) osType = 'linux';\n  else if (/windows|win\\d/i.test(hint))                    osType = 'windows';\n}\n\n// 4to intento: Zabbix Agent → Linux\nif (osType === 'unknown' && ifaces.some(i => i.type === '1')) { osType = 'linux'; }\n// 5to: SSH macros → Linux\nif (osType === 'unknown') {\n  const hasSsh = (host.macros||[]).some(m => ['{$SSH.USER}','{$SSH_USER}','{$SSH.PASSWORD}','{$SSH_PASS}'].includes(m.macro));\n  if (hasSsh) osType = 'linux';\n}\n// 6to: nombre sugiere cloud\nif (osType === 'unknown') {\n  const hint = (hostname+' '+(host.description||'')).toLowerCase();\n  if (/oracle|cloud|vm|vps|aws|gcp|azure|ubuntu|debian|centos|linux/i.test(hint)) osType = 'linux';\n}\n// Default\nif (osType === 'unknown') osType = 'linux';\n\n// ── Extraer IP principal (preferir Zabbix Agent IP o primera) ──\nconst ifaces   = host.interfaces || [];\nconst primary  = ifaces.find(i => i.main === '1' && i.type === '1')  // Zabbix Agent\n              || ifaces.find(i => i.main === '1' && i.type === '2')  // SNMP\n              || ifaces.find(i => i.main === '1')\n              || ifaces[0];\nconst hostIp   = primary\n  ? (primary.useip === '1' || primary.useip === true ? primary.ip : (primary.dns || primary.ip))\n  : null;\n\n// ── Leer credenciales SSH desde macros Zabbix ───────────────────\nconst macros = host.macros || []