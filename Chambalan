        "jsCode": "// CHAMBALAND — Preparar Comparación v2 — Multi-host\nconst gestor = $node['🗂️ Gestor de Sesión'].json;\nconst chatId  = gestor.chatId;\n// Soporte multi-host: gestor.hosts[] (nuevo) o host1/host2 (legacy)\nconst hosts = gestor.hosts?.length >= 2 ? gestor.hosts\n  : (gestor.host1 && gestor.host2 ? [gestor.host1, gestor.host2] : null);\nconst esListar  = gestor.accion === 'listar_comparables';\nconst metrica   = gestor.metrica || 'general';\nconst bucket    = gestor.bucket  || { tipo:'horas', cantidad:1, metodo:'history' };\nconst zabbixAuth = '306be4bee609f26cae91f16592efdbcdc0bc2a6f94c95f80d7d7edf04341885a'; // hardcoded — Community Edition\n\nif (!hosts || hosts.length < 2) {\n  return { error: 'Se necesitan al menos 2 hosts para comparar', chatId };\n}\n\n// Calcular rango de tiempo\nconst now = Math.floor(Date.now()/1000);\nlet timeFrom, timeTill = now, metodo;\nswitch(bucket.tipo) {\n  case 'horas':    timeFrom = now - (bucket.cantidad * 3600);    metodo = 'history'; break;\n  case 'dias':     timeFrom = now - (bucket.cantidad * 86400);   metodo = bucket.cantidad > 2 ? 'trend' : 'history'; break;\n  case 'semanas':  timeFrom = now - (bucket.cantidad * 7*86400); metodo = 'trend'; break;\n  case 'meses':    timeFrom = now - (bucket.cantidad * 30*86400);metodo = 'trend'; break;\n  case 'año':      timeFrom = now - (365*86400);                 metodo = 'trend'; break;\n  case 'especifico': timeFrom = bucket.timeFrom; timeTill = bucket.timeTill||now; metodo = 'history'; break;\n  default:         timeFrom = now - 3600; metodo = 'history';\n}\n\nconst tagMap = {\n  cpu:         [{ tag:'component', value:'cpu',         operator:1 }],\n  ram:         [{ tag:'component', value:'memory',      operator:1 }],\n  disco:       [{ tag:'component', value:'storage',     operator:1 }],\n  red:         [{ tag:'component', value:'network',     operator:1 },\n                { tag:'component', value:'health',      operator:1 }],\n  os:          [{ tag:'component', value:'os',          operator:1 }],\n  temperatura: [{ tag:'component', value:'temperature', operator:1 }],\n};\nconst labelMap = { cpu:'CPU', ram:'RAM', disco:'Disco', red:'Red', os:'Sistema', temperatura:'Temperatura', general:'General' };\nconst partes   = metrica.toLowerCase().split('+').map(p=>p.trim()).filter(Boolean);\nconst esGen    = partes.includes('general') || partes.length === 0;\nconst etiqueta = esGen ? 'Estado General' : partes.map(p=>labelMap[p]||p).join(' + ');\n\n// ── Nombre literal que el usuario mencionó (p.ej. \"total memory\") ──\nconst metricaRaw = (gestor.metricaRaw || '').trim().toLowerCase();\n\n// useNameSearch: independiente de esGen — si el usuario nombró un ítem específico\n// multi-palabra usamos búsqueda por nombre SIN importar si también dijo \"todos los hosts\"\nconst useNameSearch = metricaRaw.length >= 5 && metricaRaw.includes(' ');\n\n// esGen: solo true si la CATEGORÍA es general Y no hay nombre específico\nconst esGenCategory = partes.includes('general') || partes.length === 0;\nconst esGen2 = esGenCategory && !useNameSearch;  // sobrescribe esGen local para itemParams\n\n// ── Ajuste de ventana temporal ────────────────────────────────────────────────\n// IMPORTANTE: NO forzamos trend — en muchos Zabbix el trend storage no está activo.\n// Para nameSearch: 7 días porque ítems estáticos (Total memory, uptime) se colectan poco frecuente\n// Para esGen: mínimo 3h de historia para asegurar que los items dinámicos tengan datos\nif (useNameSearch) {\n  // Extender a 7 días para capturar ítems con baja frecuencia de colección\n  timeFrom = now - 7 * 86400;\n  timeTill = now;\n  metodo   = 'history';   // history siempre (trend puede no existir)\n} else if (esGen2 && metodo === 'history') {\n  // Para general: mínimo 3 horas para asegurar cobertura\n  timeFrom = Math.min(timeFrom, now - 3 * 3600);\n}\n\nconst itemParams = {\n  // Incluir value_type y lastvalue: CRÍTICO para fallback cuando history.get no retorna datos\n  // history.get con history=0 (float) NO devuelve ítems uint64 (p.ej. Total memory en bytes).\n  // Usando lastvalue directamente de item.get obtenemos el último valor sin importar el tipo.\n  output:       ['itemid','name','units','key_','hostid','hosts','value_type','lastvalue','lastclock'],\n  hostids:      hosts.map(h => h.id),\n  with_trends:  1,\n  with_history: 1,\n  sortfield:    'name',\n  value_type:   [0, 3],   // Solo numéricos: float (0) y uint64 (3)\n  limit:        esGen2 ? 1000 : 300\n};\n\nif (!esGen2) {\n  if (useNameSearch) {\n    // Búsqueda por nombre específico: \"Total memory\", \"CPU utilization\", etc.\n    itemParams.searchWildcardsEnabled = true;\n    itemParams.search = { name: metricaRaw };\n    // Sin tag filter — nombre es más preciso\n  } else {\n    // Búsqueda por tag de categoría (cpu, ram, disco...)\n    const tagsSet = new Map();\n    for (const p of partes) {\n      for (const t of (tagMap[p]||[])) {\n        const k = t.tag+':'+t.value;\n        if (!tagsSet.has(k)) tagsSet.set(k, t);\n      }\n    }\n    const tagsArr = [...tagsSet.values()];\n    if (tagsArr.length > 0) { itemParams.tags = tagsArr; itemParams.evaltype = 2; }\n  }\n}\n\nconst itemBody = JSON.stringify({ jsonrpc:'2.0', method:'item.get', params:itemParams, auth:zabbixAuth, id:1 });\nreturn { itemBody, timeFrom, timeTill, metodo, etiqueta, metrica, metricaRaw,\n         hosts, chatId, bucket, zabbixAuth, esListar, useNameSearch, esGen: esGen2 };\n"
