      "parameters": {
        "jsCode": "// CHAMBALAND — Generar HTML PDF v9 — Profesional + metadata para Enviar PDF\nconst sesionData   = $node['🗂️ Gestor de Sesión'].json;\nconst queryData    = $node['Preparar Query PDF'].json;\nconst etiqueta     = queryData?.etiqueta || 'General';\nconst esTodosHosts = queryData?.esTodosHosts || false;\nconst nombre       = sesionData.nombre || 'Usuario';\nconst hostNombre   = esTodosHosts ? 'Todos los hosts' : (sesionData.host?.nombre || 'Servidor');\nconst _ahoraFallback = new Date().toLocaleString('es-CO', { timeZone:'America/Bogota' });\n\nconst SKIP_COMP = ['raw','gathering-process','internal-process','nvps'];\nconst SKIP_KEY  = ['get data','discovery rule','snmp walk','zabbix agent'];\nconst zabbixItems = ($json.result || []).filter(i => {\n  // FIX v14: excluir items nunca colectados (lastclock=0 = valor ficticio)\n  if (parseInt(i.lastclock||'0') === 0) return false;\n  if (i.lastvalue===undefined||i.lastvalue===null||i.lastvalue==='') return false;\n  const comp=(i.tags||[]).find(t=>t.tag==='component')?.value||'';\n  if (SKIP_COMP.includes(comp)) return false;\n  const val=String(i.lastvalue||'');\n  if (val.startsWith('{')||val.startsWith('[')) return false;\n  const name=(i.name||'').toLowerCase();\n  if (SKIP_KEY.some(k=>name.includes(k))) return false;\n  return true;\n});\n\n// Mostrar rango del período consultado (histórico) o fallback a lastclock/fecha actual\nconst _bucket    = queryData?.bucket || sesionData?.bucket || null;\nlet ahora;\nif (_bucket && _bucket.timeFrom && _bucket.timeTill) {\n  // Reporte histórico: mostrar rango exacto solicitado\n  const _fmtOpts = { timeZone:'America/Bogota', dateStyle:'short', timeStyle:'short' };\n  const _fromStr = new Date(_bucket.timeFrom * 1000).toLocaleString('es-CO', _fmtOpts);\n  const _tillStr = new Date(_bucket.timeTill * 1000).toLocaleString('es-CO', _fmtOpts);\n  ahora = `${_fromStr} → ${_tillStr}`;\n} else if (_bucket && _bucket.label) {\n  ahora = _bucket.label;\n} else {\n  // Fallback: lastclock del dato más reciente o fecha actual\n  const _maxClockPDF = ($json.result || []).reduce((max, item) => Math.max(max, parseInt(item.lastclock||'0')), 0);\n  ahora = _maxClockPDF > 0\n    ? new Date(_maxClockPDF * 1000).toLocaleString('es-CO', { timeZone:'America/Bogota' })\n    : _ahoraFallback;\n}\n\nif (!zabbixItems.length) {\n  return { html:`<!DOCTYPE html><html><head><meta charset=\"UTF-8\"><style>body{background:#0f172a;color:#e2e8f0;font-family:sans-serif;display:flex;align-items:center;justify-content:center;height:100vh;margin:0}</style></head><body><div style=\"text-align:center;padding:40px\"><div style=\"font-size:64px\">🔭</div><h2 style=\"color:#f87171\">Sin datos</h2><p style=\"color:#94a3b8\">No se encontraron métricas para <strong>${hostNombre}</strong></p></div></body></html>`,\n    hostNombre, etiqueta, cantidadItems:0, iconoGlobal:'⚪', estadoGlobal:'Sin datos' };\n}\n\nfunction parseItem(item) {\n  const raw=item.lastvalue; const u=(item.units||'').trim(); const k=(item.key_||'').toLowerCase(); const v=parseFloat(raw);\n  if (isNaN(v)) return { display:String(raw).substring(0,50), color:'#94a3b8', bg:'#1e293b', status:'Info', icon:'ℹ️', pct:null };\n  if (u==='%') {\n    const pct=Math.min(100,Math.max(0,v)); const esFree=/free|avail|idle|pfree/.test(k);\n    let c,b,s,ic;\n    if(esFree){if(pct<5){c='#f87171';b='#3f1010';s='Crítico';ic='🔴';}else if(pct<15){c='#fbbf24';b='#3f2e10';s='Advertencia';ic='🟡';}else{c='#34d399';b='#0f3020';s='Normal';ic='🟢';}}\n    else{if(pct>90){c='#f87171';b='#3f1010';s='Crítico';ic='🔴';}else if(pct>75){c='#fbbf24';b='#3f2e10';s='Advertencia';ic='🟡';}else{c='#34d399';b='#0f3020';s='Normal';ic='🟢';}}\n    return { display:`${v.toFixed(1)}%`, color:c, bg:b, status:s, icon:ic, pct };\n  }\n  if (u==='bps'||u==='Bps') { let d; if(v>=1e9) d=(v/1e9).toFixed(2)+' Gbps'; else if(v>=1e6) d=(v/1e6).toFixed(2)+' Mbps'; else if(v>=1e3) d=(v/1e3).toFixed(1)+' Kbps'; else d=v.toFixed(0)+' bps'; return { display:d, color:'#60a5fa', bg:'#1e2a3f', status:'Info', icon:'🔵', pct:null }; }\n  if (u==='B'||/memory|disk|vfs|fs|storage/.test(k)) { const isFree=/free|avail/.test(k); let d; if(v>=1073741824) d=(v/1073741824).toFixed(2)+' GB'; else if(v>=1048576) d=(v/1048576).toFixed(1)+' MB'; else d=(v/1024).toFixed(0)+' KB'; const c=isFree&&v<536870912?'#f87171':isFree&&v<2147483648?'#fbbf24':'#34d399'; return { display:d, color:c, bg:'#1e293b', status:'Info', icon:'💾', pct:null }; }\n  if (u==='s') { let d; if(v>=86400) d=(v/86400).toFixed(1)+' días'; else if(v>=3600) d=(v/3600).toFixed(1)+' h'; else if(v>=60) d=(v/60).toFixed(0)+' min'; else d=v.toFixed(0)+' s'; return { display:d, color:'#a78bfa', bg:'#2e1f4f', status:'Info', icon:'⏱️', pct:null }; }\n  if (u) return { display:`${v.toFixed(2)} ${u}`, color:'#94a3b8', bg:'#1e293b', status:'Info', icon:'📊', pct:null };\n  return { display:v.toFixed(2), color:'#94a3b8', bg:'#1e293b', status:'Info', icon:'📊', pct:null };\n}\n\nconst CI = { cpu:'🖥️', memory:'🧠', storage:'💾', network:'🌐', health:'💚', os:'🐧', system:'⚙️', temperature:'🌡️', security:'🔐', application:'📦', environment:'🌍' };\nconst CL = { cpu:'CPU', memory:'Memoria RAM', storage:'Almacenamiento', network:'Red', health:'Conectividad', os:'Sistema Operativo', system:'Sistema', temperature:'Temperatura', security:'Seguridad', application:'Aplicaciones', environment:'Ambiente' };\nconst CO = ['cpu','memory','storage','network','health','temperature','os','system','security','application'];\n\nlet gCrit=0,gWarn=0,gOk=0;\nfor (const item of zabbixItems) { const p=parseItem(item); if(p.status==='Crítico') gCrit++; else if(p.status==='Advertencia') gWarn++; else if(p.status==='Normal') gOk++; }\nconst hColor=gCrit>0?'#f87171':gWarn>0?'#fbbf24':'#34d399';\nconst hText=gCrit>0?'CRÍTICO':gWarn>0?'ADVERTENCIA':'NORMAL';\nconst hIcon=gCrit>0?'🔴':gWarn>0?'🟡':'🟢';\n\nfunction renderRows(items) {\n  return items.map(item => {\n    const p=parseItem(item);\n    const badge=`<span style=\"ba