        "jsCode": "// CHAMBALAND — Armar Body Comparación v1\nconst prep     = $node['🔀 Preparar Comparación'].json;\nconst itemsRaw = $json.result || [];\n// Si es modo listado, no necesitamos historial — devolver directo\nif (prep.esListar) {\n  // Para listar comparables: incluir TODOS los types (texto también es útil para ver cobertura)\n  // Solo excluir núcleos CPU individuales y ítems sin nombre\n  const itemsFull = itemsRaw.filter(it => !((it.key_||'').match(/cpu\\[cpu\\d+/i)) && it.name);\n  return { ...prep, items: itemsFull, esListar: true };\n}\n\nif (!itemsRaw.length) {\n  return { ...prep, noItemsFound: true, items: [] };\n}\n\n// Filtrar items: quitar núcleos individuales de CPU\nconst items = itemsRaw.filter(it => !((it.key_||'').match(/cpu\\[cpu\\d+/i)));\n\nconst itemids = items.map(i => i.itemid);\nconst metodo  = prep.metodo;\nconst histMethod = metodo === 'trend' ? 'trend.get' : 'history.get';\n\n// Límite adaptativo: garantizar suficientes puntos por ítem\n// Para ítems estáticos (Total memory, etc.) colectados 1x/hora en 7 días → 168 pts max por ítem\n// Para ítems dinámicos (CPU, RAM util) colectados 1x/min en 3h → 180 pts por ítem\n// Calculamos: items.length × 200 pts/item, cap en 20000 para no saturar la API\nconst basePerItem = prep.useNameSearch ? 200 : (prep.esGen ? 100 : 150);\nconst histLimit   = metodo === 'trend'\n  ? Math.min(items.length * 10, 20000)\n  : Math.min(items.length * basePerItem, 20000);\n\nconst histParams = {\n  output:    ['itemid','clock','value'],\n  itemids,\n  time_from: prep.timeFrom,\n  time_till: prep.timeTill,\n  sortfield: 'clock',\n  sortorder: 'ASC',\n  limit:     Math.max(histLimit, 500)  // Mínimo 500 siempre\n};\n// history=0 → tabla de floats. Para uint64 (Total memory) el valor vendrá de lastvalue.\nif (metodo !== 'trend') histParams.history = 0;\n\nconst histBody = JSON.stringify({\n  jsonrpc: '2.0', method: histMethod,\n  params: histParams, auth: prep.zabbixAuth, id: 2\n});\nreturn { ...prep, histBody, items, esListar: false };\n"
