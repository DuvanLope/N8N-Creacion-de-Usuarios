nconst itemParams = {\n  output:    ['itemid','name','units','key_','value_type','hostid'],\n  selectHosts: ['name','hostid'],\n  selectTags: ['tag','value'],\n  monitored: true,\n  sortfield: 'name',\n  limit: 200\n};\nif (!esTodos) itemParams.hostids = [hostId];\nif (!esGen) {\n  const tagsSet = new Map();\n  for (const p of partes) {\n    for (const t of (tagMap[p]||[])) {\n      const k=t.tag+':'+t.value;\n      if (!tagsSet.has(k)) tagsSet.set(k, t);\n    }\n  }\n  const tags=[...tagsSet.values()];\n  if (tags.length) { itemParams.tags=tags; itemParams.evaltype=2; }\n} else {\n  itemParams.tags=[\n    { tag:'component', value:'cpu',     operator:1 },\n    { tag:'component', value:'memory',  operator:1 },\n    { tag:'component', value:'storage', operator:1 },\n    { tag:'component', value:'network', operator:1 },\n  ];\n  itemParams.evaltype=2;\n}\n\nconst itemBody = JSON.stringify({ jsonrpc:'2.0', method:'item.get', params:itemParams, auth:zabbixAuth, id:1 });\nreturn { itemBody, timeFrom, timeTill, metodo, etiqueta, bucket, hostId, esTodos, metrica, zabbixAuth };"
