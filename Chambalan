txt += `\\n${SEP}`;\ntxt += `📊 _${enTodos.length} en todos · ${enAlgunos.length} parciales · ${enUno.length} exclusivos_\\n`;\ntxt += sugerencia;\n\nreturn {\n  chatId,\n  mensaje: txt,\n  reply_markup: JSON.stringify({ inline_keyboard: [\n    (enTodos.length + enAlgunos.length) > 0\n      ? [{ text:`📊 Comparar todo (${enTodos.length + enAlgunos.length} métricas)`, callback_data:'btn_volver_metricas' }]\n      : [],\n    [{ text:'🔄 Otra consulta', callback_data:'btn_volver_metricas' },\n     { text:'🔙 Volver',       callback_data:'btn_volver_acciones'  }]\n  ].filter(r => r.length)})\n};\n"
