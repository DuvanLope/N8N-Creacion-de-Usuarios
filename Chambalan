      "parameters": {
        "jsCode": "// CHAMBALAND — Gestor de Sesión v6 — Flujo corregido + NLP global\nconst msg      = $node['Telegram Trigger'].json.message;\nconst callback = $node['Telegram Trigger'].json.callback_query;\n\nconst chatId = (msg?.chat?.id || callback?.message?.chat?.id || '').toString();\nconst texto  = (msg?.text || callback?.data || '').trim();\nconst nombre = $node['🔐 Seguridad'].json.nombre;\n\nif (!chatId) return { accion:'error_opcion', chatId:'0', nombre:'Unknown' };\n\nconst sesionRaw = $getWorkflowStaticData('global');\nif (!sesionRaw.sesiones) sesionRaw.sesiones = {};\nconst sesiones = sesionRaw.sesiones;\nconst sesion   = sesiones[chatId] ? { ...sesiones[chatId] } : { estado:'inicio' };\nconst op       = texto.toLowerCase().trim();\n\nfunction save(patch) {\n  // Escritura atómica por chatId: re-leer estado actual para no sobrescribir otros usuarios\n  if (!sesionRaw.sesiones) sesionRaw.sesiones = {};\n  const current = sesionRaw.sesiones[chatId] || {};\n  sesionRaw.sesiones[chatId] = { ...current, ...patch };\n}\nfunction ret(accion, extra={}) {\n  return { accion, chatId, nombre,\n    host:    sesion.host,\n    metrica: sesion.metrica,\n    bucket:  sesion.bucket || null,\n    esCallback: !!callback,\n    ...extra };\n}\n// Resetear a selección de métrica limpia\nfunction irAMetricas() {\n  save({ estado:'esperando_metrica', metricasAcumuladas:[], metrica:'', bucket:null });\n  return ret('mostrar_metricas', { metricasAcumuladas:[] });\n}\n\n// ── Detectores de lenguaje natural ───────────────────────────\nfunction detectarComparacion(t) {\n  const norm = s => (s||'').toLowerCase().normalize('NFD').replace(/[\\u0300-\\u036f]/g,'');\n  const tl   = norm(t);\n\n  const isComp = /\\bcompar(?:[ae]r?|acion)\\b|\\bvs\\b|\\bversus\\b|\\bdiferencia\\s+(?:de|entre)\\b|\\bcontra\\b/i.test(tl);\n  if (!isComp) return null;\n\n  const rawHosts   = sesion.listaHosts?.length ? sesion.listaHosts : (sesionRaw.allHosts || []);\n  const sorted     = [...rawHosts].sort((a,b) => (b.name||'').length - (a.name||'').length);\n  const sessionH   = sesion.host?.id ? { hostid: sesion.host.id, name: sesion.host.nombre } : null;\n\n  // \"todos los hosts\" → comparar todos\n  if (/\\btodos\\s*(los\\s*)?(hosts?|servidores?|equipos?)?\\b/i.test(tl) && rawHosts.length >= 2) {\n    return { hosts: rawHosts.map(h => ({ id: h.hostid, nombre: h.name })), allHosts: true };\n  }\n\n  // Self-reference: \"este servidor / este host / el actual\"\n  const selfRef = /\\beste\\s*(servidor|host|equipo)\\b|\\bel\\s*(servidor|host)\\s*(actual|activo)\\b|\\bel\\s*actual\\b/i.test(tl);\n  const found   = [];\n\n  // Match host names (sin tildes, sin mayúsculas)\n  for (const h of sorted) {\n    const hn = norm(h.name);\n    if (hn.length >= 3 && tl.includes(hn) && !found.find(f => f.hostid === h.hostid)) {\n      found.push(h);\n    }\n  }\n\n  // Agregar host activo si 'este servidor' fue mencionado\n  if (selfRef && sessionH && !found.find(f => f.hostid === sessionH.hostid)) {\n    found.unshift(sessionH);\n  }\n\n  // Fallback: solo 1 host externo → comparar con el activo de sesión\n  if (found.length === 1 && sessionH && found[0].hostid !== sessionH.hostid) {\n    found.unshift(sessionH);\n  }\n\n  if (found.length >= 2) {\n    return { hosts: found.map(h => ({ id: h.hostid, nombre: h.name })) };\n  }\n  return null;\n}\n\nfunction detectarBucket(t) {\n  const tl = (t || '').toLowerCase().trim();\n  const COL_H = 5; // Colombia = UTC-5\n\n  // === FUTURE DETECTION ===\n  if (/\\bma\\xf1ana\\b|\\bpr\\xf3xim[ao]s?\\b|\\ben\\s+\\d+\\s*(hora|d\\xeda|semana|mes|a\\xf1o)s?\\s*(m\\xe1s|despu\\xe9s)\\b/i.test(tl)\n      && !/\\bayer\\b|\\bhace\\b|\\bpasad[ao]\\b|\\b\\xfaltim[ao]\\b/i.test(tl)) {\n    return { esFuturo: true };\n  }\n\n  // === HELPERS ===\n  const colNow = new Date(new Date().toLocaleString('en-US', { timeZone:'America/Bogota' }));\n  const nowTs  = Math.floor(Date.now() / 1000);\n\n  // Colombia local datetime → UTC unix timestamp (Colombia = UTC-5)\n  function toTs(cY, cM, cD, cH, cMin) {\n    return Math.floor(Date.UTC(cY, cM, cD, cH + COL_H, cMin) / 1000);\n  }\n\n  // Parse hour:minute from text → {h, m} or null\n  function parseHora(s) {\n    // PRIORITY 1: 12h WITH am/pm / \"de la tarde\" — check BEFORE generic 24h to avoid false matches\n    // e.g. \"5:30 pm\" must become 17:30, not 05:30\n    const m12 = s.match(/\\b(\\d{1,2})(?::(\\d{2}))?\\s*(?:(pm|am)|(?:de\\s*la\\s*(tarde|noche|madrugada|ma[ñn]ana)))\\b/i);\n    if (m12) {\n      let h = parseInt(m12[1]);\n      const min = parseInt(m12[2] || '0');\n      const tag = (m12[3] || m12[4] || '').toLowerCase();\n      if (/pm|tarde|noche/.test(tag) && h < 12) h += 12;\n      if (/am|ma[ñn]?ana|madrugada/.test(tag) && h === 12) h = 0;\n      if (h >= 0 && h <= 23 && min >= 0 && min <= 59) return { h, m: min };\n    }\n    // PRIORITY 2: 24h format \"17:30\", \"17h30\" — negative lookahead to skip if followed by am/pm\n    const m24 = s.match(/\\b(\\d{1,2})[h:](\\d{2})(?!\\s*(?:am|pm|de\\s*la))\\b/);\n    if (m24) {\n      const h = parseInt(m24[1]), m = parseInt(m24[2]);\n      if (h >= 0 && h <= 23 && m >= 0 && m <= 59) return { h, m };\n    }\n    // PRIORITY 3: \"a las 17\", \"a las 5:30\" (no am/pm context needed — assume 24h or reasonable)\n    const mAlas = s.match(/a\\s+las?\\s+(\\d{1,2})(?::(\\d{2}))?\\b/);\n    if (mAlas) {\n      const h = parseInt(mAlas[1]), min = parseInt(mAlas[2] || '0');\n      if (h >= 0 && h <= 23 && min >= 0 && min <= 59) return { h, m: min };\n    }\n    return null;\n  }\n\n  // Parse Colombia date from text → {cY, cM, cD} or null\n  function parseFecha(s) {\n    const tn = s.normalize('NFD').replace(/[\\u0300-\\u036f]/g, '');\n    const [cY, cM, cD] = [colNow.getFullYear(), colNow.getMonth(), colNow.getDate()];\n    if (/\\bhoy\\b/.test(tn)) return { cY, cM, cD };\n    if (/\\bayer\\b/.test(tn)) {\n      const d = new Date(Date.UTC(cY, cM, cD)); d.setUTCDate(d.getUTCDate() - 1);\n      return { cY: d.getUTCFullYear(), cM: d.getUTCMonth(), cD: d.getUTCDate() };\n    }\n    // Día de la semana\n    const diasMap = { lunes:1, martes:2, mier:3, miercoles:3, jueves:4, viernes:5, sabado:6, domingo:0 };\n    for (const [dname, dnum] of Object.entries(diasMap)) {\n      if (tn.includes(dname)) {\n        let diff = ((colNow.getDay() - dnum) + 7) % 7;\n        if (diff === 0) diff = 7; // si es hoy, asumir la semana pasada\n        const d = new Date(Date.UTC(cY, cM, cD)); d.setUTCDate(d.getUTCDate() - diff);\n        return { cY: d.getUTCFullYear(), cM: d.getUTCMonth(), cD: d.getUTCDate() };\n      }\n    }\n    // \"29 de marzo\", \"el 29 de marzo\"\n    const mesesMap = { enero:0, febrero:1, marzo:2, abril:3, mayo:4, junio:5,\n      julio:6, agosto:7, septiembre:8, octubre:9, noviembre:10, diciembre:11 };\n    const mNom = tn.match(/\\b(\\d{1,2})\\s+de\\s+([a-z]+)/);\n    if (mNom) {\n      const dia = parseInt(mNom[1]);\n      const mes = mesesMap[mNom[2]];\n      if (mes !== undefined && dia >= 1 && dia <= 31) {\n        let yr = cY;\n        if (Date.UTC(yr, mes, dia) > Date.UTC(cY, cM, cD)) yr--;\n        return { cY: yr, cM: mes, cD: dia };\n      }\n    }\n    // DD/MM o DD-MM\n    const mNum = s.match(/\\b(\\d{1,2})[\\/\\-](\\d{1,2})(?:[\\/\\-](\\d{2,4}))?\\b/);\n    if (mNum) {\n      const dia = parseInt(mNum[1]), mes = parseInt(mNum[2]) - 1;\n      let yr = mNum[3] ? (mNum[3].length===2 ? 2000+parseInt(mNum[3]) : parseInt(mNum[3])) : cY;\n      if (dia >= 1 && dia <= 31 && mes >= 0 && mes <= 11) return { cY: yr, cM: mes, cD: dia };\n    }\n    return null;\n  }\n\n  // Normalize Spanish number words → digits\n  const numWords = {\n    'cero ':'0 ','un ':'1 ','una ':'1 ','uno ':'1 ','dos ':'2 ','tres ':'3 ','cuatro ':'4 ','cinco ':'5 ',\n    'seis ':'6 ','siete ':'7 ','ocho ':'8 ','nueve ':'9 ','diez ':'10 ','once ':'11 ','doce ':'12 ',\n    'trece ':'13 ','catorce ':'14 ','quince ':'15 ','veinte ':'20 ','veinticuatro ':'24 ','treinta ':'30 '\n  };\n  let t2 = tl + ' ';\n  for (const [w, n] of Object.entries(numWords)) {\n    while (t2.includes(w)) t2 = t2.replace(w, n);\n  }\n\n  // === PRIORIDAD 1: HORA ESPECÍFICA (\"a las 5:30 pm\", \"17:30\", \"5pm del día de hoy\") ===\n  const hasHoraPattern = /a\\s+las?\\s+\\d|\\b\\d{1,2}:\\d{2}\\b|\\b\\d{1,2}h\\d{2}\\b|\\b\\d{1,2}\\s*(?:am|pm)\\b|de\\s+la\\s+(?:tarde|noche|madrugada|ma[ñn]ana)/i;\n  if (hasHoraPattern.test(tl)) {\n    const hora = parseHora(tl);\n    if (hora) {\n      const fecha = parseFecha(tl);\n      const fb = fecha || { cY: colNow.getFullYear(), cM: colNow.getMonth(), cD: colNow.getDate() };\n      const targetTs = toTs(fb.cY, fb.cM, fb.cD, hora.h, hora.m);\n\n      if (targetTs > nowTs + 300) return { esFuturo: true }; // más de 5 min en el futuro\n\n      // Ventana: 15 min antes — 90 min después del tiempo pedido\n      const timeFrom = targetTs - 900;\n      const timeTill = Math.min(targetTs + 5400, nowTs);\n\n      const timeStr = `${hora.h.toString().padStart(2,'0')}:${hora.m.toString().padStart(2,'0')}`;\n      const dateStr = fecha\n        ? `${fb.cD}/${(fb.cM+1).toString().padStart(2,'0')}/${fb.cY} `\n        : '';\n      const label = `${dateStr}a las ${timeStr}`;\n\n      return { tipo:'especifico', timeFrom, timeTill, timePico: targetTs, label, metodo:'history' };\n    }\n  }\n\n  // === PRIORIDAD 2: FECHA ESPECÍFICA SIN HORA (\"el martes\", \"el 29 de marzo\") ===\n  const hasRelativo = /\\b[uú]ltim[ao]s?\\b|\\bhace\\b|\\bayer\\b|\\bhoy\\b/i.test(tl);\n  if (!hasRelativo) {\n    const fecha = parseFecha(tl);\n    if (fecha) {\n      const dayStart = toTs(fecha.cY, fecha.cM, fecha.cD, 0, 0);\n      const dayEnd   = Math.min(toTs(fecha.cY, fecha.cM, fecha.cD, 23, 59), nowTs);\n      const dateStr  = `${fecha.cD}/${(fecha.cM+1).toString().padStart(2,'0')}/${fecha.cY}`;\n      return { tipo:'especifico', timeFrom: dayStart, timeTill: dayEnd, timePico: null, label: `El ${dateStr}`, metodo:'history' };\n    }\n  }\n\n  // === PRIORIDAD 3: TIEMPO RELATIVO (lógica existente) ===\n  if (/\\xfaltimo\\s*a\\xf1o|este\\s*a\\xf1o/i.test(t2))\n    return { tipo:'a\\xf1o', cantidad:1, label:'Último año', metodo:'trend' };\n\n  const meses = t2.match(/\\xfaltimos?\\s*(\\d+)\\s*mes/i);\n  if (meses) return { tipo:'meses', cantidad:parseInt(meses[1]), label:'Últimos '+meses[1]+' meses', metodo:'trend' };\n  if (/\\xfaltimo\\s*mes|este\\s*mes/i.test(t2))\n    return { tipo:'meses', cantidad:1, label:'Último mes', metodo:'trend' };\n\n  const semanas = t2.match(/\\xfaltimas?\\s*(\\d+)\\s*semana/i);\n  if (semanas) return { tipo:'semanas', cantidad:parseInt(semanas[1]), label:'Últimas '+semanas[1]+' semanas', metodo:'trend' };\n  if (/\\xfaltima\\s*semana|esta\\s*semana|semana\\s*pasada/i.test(t2))\n    return { tipo:'semanas', cantidad:1, label:'Última semana', metodo:'trend' };\n\n  // \"hace N días\" → día calendario específico (no ventana rolling)\n  const haceNDias = t2.match(/\\bhace\\s*(\\d+)\\s*d[ií]as?(?:\\s*atr[aá]s?)?\\b/i);\n  if (haceNDias && !/[uú]ltimos?/.test(t2.substring(0, haceNDias.index || 0))) {\n    const n = parseInt(haceNDias[1]);\n    if (n > 0) {\n      const d = new Date(Date.UTC(colNow.getFullYear(), colNow.getMonth(), colNow.getDate()));\n      d.setUTCDate(d.getUTCDate() - n);\n      const dayStart = toTs(d.getUTCFullYear(), d.getUTCMonth(), d.getUTCDate(), 0, 0);\n      const dayEnd   = Math.min(toTs(d.getUTCFullYear(), d.getUTCMonth(), d.getUTCDate(), 23, 59), nowTs);\n      const dd = String(d.getUTCDate()).padStart(2,'0');\n      const mm = String(d.getUTCMonth()+1).padStart(2,'0');\n      const yy = d.getUTCFullYear();\n      return { tipo:'especifico', timeFrom: dayStart, timeTill: dayEnd, timePico: null,\n               label: `El ${dd}/${mm}/${yy}`, metodo:'history' };\n    }\n  }\n  // \"últimos N días\" → ventana rolling\n  const dias = t2.match(/[uú]ltimos?\\s*(\\d+)\\s*d[ií]as?/i);\n  if (dias) { const c=parseInt(dias[1]); if(c>0) return { tipo:'dias', cantidad:c, label:'Últimos '+c+' días', metodo:c>2?'trend':'history' }; }\n  if (/\\bayer\\b/i.test(t2)) return { tipo:'dias', cantidad:1, label:'Ayer', metodo:'history' };\n\n  // \"hace N minutos\" → punto de tiempo específico\n  const haceMinutos = t2.match(/\\bhace\\s*(\\d+)\\s*minutos?(?:\\s*atr[aá]s?)?\\b/i);\n  if (haceMinutos) {\n    const n = parseInt(haceMinutos[1]);\n    if (n > 0) {\n      const timePico = nowTs - n * 60;\n      const timeFrom = Math.max(timePico - 600, nowTs - 7200); // hasta 10 min antes, max 2h atrás\n      const timeTill = Math.min(timePico + 300, nowTs);\n      return { tipo:'especifico', timeFrom, timeTill, timePico,\n               label: `Hace ${n} minuto${n>1?'s':''}`, metodo:'history' };\n    }\n  }\n  // \"hace N horas\" / \"últimas N horas\" → ventana rolling\n  const horas = t2.match(/(?:\\xfaltimas?\\s*(\\d+)\\s*horas?|hace\\s*(\\d+)\\s*horas?(?:\\s*atr\\xe1s?)?)/i);\n  if (horas) { const c=parseInt(horas[1]||horas[2]); if(c>0) return { tipo:'horas', cantidad:c, label:'Últimas '+c+' horas', metodo:'history' }; }\n  if (/\\bhoy\\b/i.test(t2)) return { tipo:'horas', cantidad:24, label:'Hoy (24h)', metodo:'history' };\n\n  return null;\n}\nfunction detectarMetrica(t) {\n  if (/\\bcpu\\b|procesador|núcleo|core/i.test(t)) return 'cpu';\n  if (/\\bram\\b|\\bmemoria\\b|\\bmemory\\b/i.test(t)) return 'ram';\n  if (/\\bdisco\\b|storage|almacen/i.test(t)) return 'disco';\n  if (/\\bred\\b|\\bnetwork\\b|interfaz|tráfico|ancho\\s*de\\s*banda|bps|bits/i.test(t)) return 'red';\n  if (/\\bos\\b|sistema\\s*operativo|uptime|tiempo\\s*encendido/i.test(t)) return 'os';\n  if (/temperatura|temp\\b/i.test(t)) return 'temperatura';\n  // 'general' solo si el usuario pide todos los ITEMS/métricas, no cuando dice \"todos los hosts\"\n  if (/\\btodos?\\s+(?:los\\s+|las\\s+)?(?:items?|m[eé]tricas?|indicadores?|datos?)\\b|\\bgeneral\\b|\\bestado\\s*general\\b|\\btodo\\b/i.test(t)) return 'general';\n  return null;\n}\n// Extrae el nombre LITERAL del ítem/métrica que el usuario mencionó\n// p.ej. \"compara el total memory\" → \"total memory\"\nfunction extractMetricaRaw(t) {\n  const norm = s => (s||'').normalize('NFD').replace(/[\\u0300-\\u036f]/g,'');\n  const tl   = norm(t).toLowerCase();\n  // Captura lo que viene después del verbo de comparación + artículo opcional\n  const m = tl.match(\n    /compar[ae](?:ndo|r)?\\s+(?:(?:el|la|los|las|todos?(?:\\s+los)?)\\s+)?([a-z][a-z\\s_\\-]{2,40}?)(?:\\s+(?:de[l]?|en|con|entre|del|de\\s+los|en\\s+todos?|con\\s+todos?)\\b|$)/i\n  );\n  if (!m) return null;\n  const raw = m[1].trim().replace(/\\s+/g,' ');\n  // Ignorar términos genéricos de categoría\n  const genericos = ['cpu','ram','disco','red','os','todo','todos','general',\n                     'item','items','metrica','metricas','indicador','indicadores',\n                     'host','hosts','servidor','servidores'];\n  if (genericos.includes(raw)) return null;\n  // Mínimo 5 chars para evitar falsos positivos cortos\n  if (raw.length < 5) return null;\n  return raw;\n}\n\n// ── Comandos globales de reset ────────────────────────────────\nconst saludos = ['hola','hi','hello','buenas','buenos dias','buen dia','inicio','start','/start','reiniciar','/help','/menu','menu'];\nif (op==='btn_menu' || saludos.some(s=>op.includes(s))) {\n  save({ estado:'esperando_host', listaHosts:sesion.listaHosts||[], metricasAcumuladas:[], metrica:'', bucket:null });\n  return ret('mostrar_hosts');\n}\nif (op==='btn_volver_acciones') {\n  save({ estado:'esperando_accion', metricasAcumuladas:[], metrica:'', bucket:null });\n  return ret('mostrar_acciones');\n}\nif (op==='btn_volver_metricas') {\n  save({ estado:'esperando_metrica', metricasAcumuladas:[], metrica:'', bucket:null });\n  return ret('mostrar_metricas', { metricasAcumuladas:[] });\n}\n\n// Integridad de sesión\nif (sesion.estado!=='inicio' && sesion.estado!=='esperando_host' && !sesion.host?.id) {\n  save({ estado:'esperando_host', listaHosts:sesion.listaHosts||[] });\n  return ret('mostrar_hosts');\n}\n\n// ── DETECCIÓN NLP GLOBAL (funciona desde cualquier estado si hay host) ────\n// Si el usuario escribe texto libre con métrica + tiempo → ruta histórico directa\nif (!callback && sesion.host?.id && !op.startsWith('btn_') &&\n    sesion.estado !== 'inicio' && sesion.estado !== 'esperando_host' &&\n    sesion.estado !== 'esperando_config_tipo' && sesion.estado !== 'esperando_config') {\n  const bucket   = detectarBucket(texto);\n  const metrica  = detectarMetrica(texto);\n  if (bucket?.esFuturo) {\n    return ret('error_futuro');\n  }\n  // ── Modificación/configuración activa → SSH (MÁXIMA PRIORIDAD) ──\n  // \"cambia\", \"configura\", \"agrega\", \"borra\", \"establece\", \"activa/desactiva\", etc.\n  const isModificacion = /\\bcambi(?:a|ar|e)\\b|\\bconfigur(?:a|ar|e)\\b|\\bagrega(?:r|\\b)|\\bañad(?:e|ir)\\b|\\belimin(?:a|ar|e)\\b|\\bborr(?:a|ar|e)\\b|\\bestablec(?:e|er)\\b|\\bdesactiv(?:a|ar|e)\\b|\\bactiv(?:a|ar|e)\\b|\\bmodific(?:a|ar|e)\\b|\\basign(?:a|ar|e)\\b|\\bpon(?:e|er|g[ao])\\b|\\bset\\s+\\w|\\brename\\b|\\bip\\s+add(?:ress)?\\b|\\bvlan\\s+\\d|\\bcrear?\\b.*\\bvlan|\\bfirewall\\b.*\\brule|\\bnat\\s+rule/i.test(texto);\n  if (isModificacion) {\n    save({ estado:'esperando_ssh', sshTexto: texto });\n    return ret('ssh_exec', { sshTexto: texto });\n  }\n\n  // ── SSH execution NLP (must come before config NLP to take priority for 'ssh' keyword) ──\n  // Triggered by: \"ssh\", \"comando remoto\", \"conectar ssh\", \"ejecutar en el router\"\n  const isSshNlp = /\\bssh\\b|\\bcomando\\s*(remoto|ssh)|\\bejecutar?\\s+(?:en\\s+el\\s+)?(?:router|host|server|servidor)\\b|\\bterminal\\s+remot|\\bconectar\\s+(?:v[ií]a\\s+)?ssh|\\bejecutar?\\s+comando\\b/i.test(texto);\n  if (isSshNlp) {\n    save({ estado:'esperando_ssh', sshTexto: texto });\n    return ret('ssh_exec', { sshTexto: texto });\n  }\n\n  // Config NLP: \"muéstrame las interfaces\", \"qué rutas tiene\", \"info del sistema\"\n  const configNlpPats = [\n    /\\binterface[s]?\\b|\\binterfaz\\b|\\binterfases\\b|\\bether\\w*\\b|\\bwlan\\w*\\b/i,\n    /\\bruta[s]?\\b|\\brouting\\b|\\bgateway\\b|\\btabla.*rut/i,\n    /\\bfirmware\\b|\\bversion.*router|\\buptime\\b.*\\bhost|\\binfo.*sistema/i,\n    /\\bvlan[s]?\\b/i,\n    /ver\\s+config|muestra.*config|configuraci[oó]n.*host|c[oó]mo.*configur/i\n  ];\n  const isConfigNlp = configNlpPats.some(p => p.test(texto)) && !metrica && !bucket;\n  if (isConfigNlp) {\n    let configSubtipo = 'general';\n    if (/interface[s]?|interfaz|interfases|ether|wlan/i.test(texto)) configSubtipo = 'interfaces';\n    else if (/ruta[s]?|routing|gateway|tabla.*rut/i.test(texto))     configSubtipo = 'rutas';\n    else if (/sistema|uptime|version|firmware|info.*sistema/i.test(texto)) configSubtipo = 'sistema';\n    save({ estado:'esperando_config_tipo', configSubtipo });\n    return ret('leer_config', { configSubtipo });\n  }\n  // ── Listar items comparables entre hosts ──\n  const isListar = /\\bqu[eé]\\s*(items?|m[eé]tricas?|indicadores?).*\\bcompar/i.test(texto)\n    || /\\b(items?|m[eé]tricas?)\\s+(en\\s+com[uú]n|comparables?)\\b/i.test(texto)\n    || /\\bqu[eé]\\s+puedo\\s+comparar\\b/i.test(texto)\n    || /\\bqu[eé]\\s+tienen\\s+en\\s+com[uú]n\\b/i.test(texto);\n  if (isListar) {\n    const compResultL = detectarComparacion(texto);\n    if (compResultL) {\n      return ret('listar_comparables', {\n        hosts: compResultL.hosts, allHosts: compResultL.allHosts||false\n      });\n    }\n    // Sin hosts específicos → listar para todos\n    const rawAllH = sesion.listaHosts?.length ? sesion.listaHosts : (sesionRaw.allHosts||[]);\n    if (rawAllH.length >= 2) {\n      return ret('listar_comparables', {\n        hosts: rawAllH.map(h => ({ id: h.hostid, nombre: h.name })), allHosts: true\n      });\n    }\n  }\n\n  // ── Detección de comparación entre hosts (mayor prioridad que cross-host) ──\n  const compResult = detectarComparacion(texto);\n  if (compResult) {\n    const compBucket  = detectarBucket(texto);\n    const compMetrica = detectarMetrica(texto);\n    if (compBucket?.esFuturo) return ret('error_futuro');\n    save({ estado:'esperando_accion', metrica: compMetrica||'general', bucket: compBucket||null });\n    const compMetricaRaw = extractMetricaRaw(texto);\n    return ret('comparar_hosts', {\n      hosts: compResult.hosts, allHosts: compResult.allHosts||false,\n      metrica: compMetrica||'general',\n      metricaRaw: compMetricaRaw || null,\n      bucket: compBucket||null\n    });\n  }\n\n  // ── Detectar si el usuario menciona un host distinto al activo → bloquear ──\n  const _rawHostsNlp = sesion.listaHosts?.length ? sesion.listaHosts\n                      : (sesionRaw.allHosts || []);\n  // Ordenar de mayor a menor longitud → coincide primero el más específico\n  const listaHostsNlp = [..._rawHostsNlp].sort((a,b) => (b.name||'').length - (a.name||'').length);\n  const txLower = texto.toLowerCase();\n  for (const h of listaHostsNlp) {\n    const hn = (h.name || '').toLowerCase();\n    if (hn.length >= 4 && h.hostid !== sesion.host.id && txLower.includes(hn)) {\n      // El usuario menciona otro host → no consultar, avisar que debe cambiar de host\n      return ret('error_cross_host', { crossHostTarget: h.name });\n    }\n  }\n  if (bucket && metrica) {\n    save({ estado:'esperando_accion', metrica, metricasAcumuladas:[metrica], bucket });\n    return ret('historico_texto', { metrica, bucket });\n  }\n  // Solo métrica en lenguaje natural → ir directo a consulta texto\n  if (metrica && !bucket) {\n    save({ estado:'esperando_accion', metrica, metricasAcumuladas:[metrica], bucket:null });\n    return ret('texto_report', { metrica });\n  }\n}\n\n// ════════════════════════════════════════════════════════════════\nswitch (sesion.estado) {\n\n  case 'inicio':\n  case 'esperando_host': {\n    let h = null;\n    if (op==='btn_todos'||op==='todos'||op==='all') {\n      h = { id:'todos', nombre:'Todos los hosts', grupos:[] };\n    } else if (texto.startsWith('btn_host_')) {\n      const idx = parseInt(texto.replace('btn_host_',''));\n      const list = sesion.listaHosts||[];\n      if (!isNaN(idx) && idx>=0 && idx<list.length)\n        h = { id:list[idx].hostid, nombre:list[idx].name, grupos:(list[idx].groups||[]).map(g=>g.name) };\n    } else {\n      const num = parseInt(texto);\n      const list = sesion.listaHosts||[];\n      if (!isNaN(num) && num>=1 && num<=list.length)\n        h = { id:list[num-1].hostid, nombre:list[num-1].name, grupos:(list[num-1].groups||[]).map(g=>g.name) };\n    }\n    if (h) {\n      save({ estado:'esperando_accion', host:h, metricasAcumuladas:[], metrica:'', bucket:null });\n      return ret('mostrar_acciones', { host:h });\n    }\n    return ret('mostrar_hosts');\n  }\n\n  case 'esperando_accion': {\n    if (op==='btn_monitoreo') {\n      save({ estado:'esperando_metrica', metricasAcumuladas:[], metrica:'', bucket:null });\n      return ret('mostrar_metricas', { metricasAcumuladas:[] });\n    }\n    if (op==='btn_ssh') {\n      save({ estado:'esperando_ssh', sshTexto:'' });\n      return ret('ssh_exec', { sshTexto: '' });\n    }\n    if (op==='btn_config') {\n      save({ estado:'esperando_config_tipo', configSubtipo:'general' });\n      return ret('mostrar_config_menu', { configSubtipo:'general' });\n    }\n    // ── Gestión de alertas proactivas ──\n    if (op==='btn_alertas') {\n      return ret('alertas_menu');\n    }\n    if (op==='btn_sub_alertas') {\n      const subs = sesionRaw.alertSubscribers || [];\n      if (!subs.includes(chatId)) sesionRaw.alertSubscribers = [...subs, chatId];\n      return ret('sub_alertas');\n    }\n    if (op==='btn_unsub_alertas') {\n      sesionRaw.alertSubscribers = (sesionRaw.alertSubscribers||[]).filter(id => id !== chatId);\n      return ret('unsub_alertas');\n    }\n    // Desde pantalla de resultado → PDF o Texto con la misma métrica ya seleccionada\n    if (op==='btn_pdf' && sesion.metrica) {\n      return ret('pdf_report', { metrica: sesion.metrica, bucket: sesion.bucket || null });\n    }\n    if (op==='btn_texto' && sesion.metrica) {\n      return ret('texto_report', { metrica: sesion.metrica });\n    }\n    return ret('mostrar_acciones');\n  }\n\n  case 'esperando_metrica': {\n    const metricaMap = {\n      'btn_cpu':'cpu','btn_ram':'ram','btn_disco':'disco','btn_red':'red',\n      'btn_os':'os','btn_general':'general','btn_temperatura':'temperatura','btn_security':'security'\n    };\n    const metrica = metricaMap[op] || null;\n\n    // btn_historico → selección de período\n    if (op==='btn_historico') {\n      save({ estado:'esperando_periodo' });\n      return ret('mostrar_periodo');\n    }\n    // btn_texto / btn_pdf SOLO si hay métricas acumuladas\n    const acum = sesion.metricasAcumuladas || [];\n    if ((op==='btn_texto'||op==='btn_pdf') && acum.length > 0) {\n      save({ estado:'esperando_accion', metrica:sesion.metrica, bucket:null });\n      return ret(op==='btn_pdf' ? 'pdf_report' : 'texto_report', { metrica:sesion.metrica });\n    }\n    if (metrica) {\n      const newAcum = sesion.metricasAcumuladas || [];\n      if (!newAcum.includes(metrica)) newAcum.push(metrica);\n      const metricaJoin = newAcum.join('+');\n      save({ estado:'esperando_metrica', metrica:metricaJoin, metricasAcumuladas:newAcum });\n      return ret('mostrar_metricas', { metrica:metricaJoin, metricasAcumuladas:newAcum });\n    }\n    return ret('mostrar_metricas', { metricasAcumuladas:sesion.metricasAcumuladas||[] });\n  }\n\n  case 'esperando_periodo': {\n    const periodos = {\n      'btn_2h':   { tipo:'horas', cantidad:2,  label:'Últimas 2 horas',  metodo:'history' },\n      'btn_6h':   { tipo:'horas', cantidad:6,  label:'Últimas 6 horas',  metodo:'history' },\n      'btn_24h':  { tipo:'horas', cantidad:24, label:'Últimas 24 horas', metodo:'history' },\n      'btn_7d':   { tipo:'dias',  cantidad:7,  label:'Últimos 7 días',   metodo:'trend'   },\n      'btn_30d':  { tipo:'meses', cantidad:1,  label:'Último mes',       metodo:'trend'   },\n      'btn_365d': { tipo:'año',   cantidad:1,  label:'Último año',       metodo:'trend'   },\n    };\n    const b = periodos[op] || detectarBucket(texto);\n    if (b) {\n      save({ estado:'esperando_metrica_hist', bucket:b, metricasAcumuladas:[], metrica:'' });\n      return ret('mostrar_metricas_hist', { bucket:b });\n    }\n    return ret('mostrar_periodo');\n  }\n\n  case 'esperando_metrica_hist': {\n    const mm = { 'btn_cpu':'cpu','btn_ram':'ram','btn_disco':'disco','btn_red':'red','btn_os':'os','btn_general':'general','btn_temperatura':'temperatura' };\n    const m = mm[op] || detectarMetrica(texto);\n    if (m) {\n      save({ estado:'esperando_accion', metrica:m, metricasAcumuladas:[m] });\n      return ret('historico_texto', { metrica:m, bucket:sesion.bucket });\n    }\n    return ret('mostrar_metricas_hist', { bucket:sesion.bucket });\n  }\n\n  case 'esperando_config': {\n    if (op==='btn_cancelar_config' || op==='btn_volver_acciones') {\n      save({ estado:'esperando_accion' });\n      return ret('mostrar_acciones');\n    }\n    if (op==='btn_confirmar_config') {\n      save({ estado:'esperando_accion' });\n      return ret('ejecutar_config');\n    }\n    if (!callback && texto.length > 2) {\n      save({ estado:'esperando_ssh', sshTexto: texto });\n      return ret('ssh_exec', { sshTexto: texto });\n    }\n    return ret('mostrar_config');\n  }\n\n  case 'esperando_config_tipo': {\n    const subMap = {\n      'btn_cfg_interfaces':'interfaces','btn_cfg_sistema':'sistema',\n      'btn_cfg_rutas':'rutas','btn_cfg_general':'general'\n    };\n    if (op==='btn_volver_acciones'||op==='btn_cancelar_config') {\n      save({ estado:'esperando_accion' });\n      return ret('mostrar_acciones');\n    }\n    const sshCmdMap = {\n      'interfaces': 'muéstrame las interfaces de red con sus IPs',\n      'rutas':      'muéstrame la tabla de rutas',\n      'sistema':    'muéstrame información del sistema: uptime, hostname, memoria y versión',\n      'general':    'muéstrame un resumen completo del sistema'\n    };\n    const subtipo = subMap[op];\n    if (subtipo) {\n      save({ estado:'esperando_ssh', configSubtipo: subtipo });\n      return ret('ssh_exec', { sshTexto: sshCmdMap[subtipo] || 'muéstrame información del sistema' });\n    }\n    if (!callback && texto.length > 2) {\n      save({ estado:'esperando_ssh', sshTexto: texto });\n      return ret('ssh_exec', { sshTexto: texto });\n    }\n    return ret('mostrar_config_menu', { configSubtipo:sesion.configSubtipo||'general' });\n  }\n\n  case 'esperando_ssh': {\n    if (op==='btn_volver_acciones' || op==='btn_cancelar_config') {\n      save({ estado:'esperando_accion' });\n      return ret('mostrar_acciones');\n    }\n    if (!callback && texto.length > 2) {\n      save({ estado:'esperando_ssh', sshTexto: texto });\n      return ret('ssh_exec', { sshTexto: texto });\n    }\n    // Re-send the SSH menu\n    return ret('ssh_exec', { sshTexto: sesion.sshTexto || '' });\n  }\n\n  default:\n    save({ estado:'esperando_host', listaHosts:sesion.listaHosts||[] });\n    return ret('mostrar_hosts');\n}"
