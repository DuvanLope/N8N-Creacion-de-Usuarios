        "jsCode": "// CHAMBALAND — Formatear Alerta Zabbix v1\n// Recibe payload de Zabbix webhook y genera mensajes para cada suscriptor\n\nconst sesionRaw     = $getWorkflowStaticData('global');\nconst subscribers   = sesionRaw.alertSubscribers || [];\n\n// Si no hay suscriptores activos, no enviar nada\nif (!subscribers.length) return [];\n\nconst body      = $json.body || $json;  // n8n webhook body\nconst hostName  = String(body.hostName  || body.host    || 'Host desconocido');\nconst hostId    = String(body.hostId    || body.hostid  || '');\nconst trigger   = String(body.triggerName || body.trigger || 'Evento desconocido');\nconst value     = String(body.value     || '');\nconst severity  = String(body.severity  || 'average').toLowerCase();\nconst status    = String(body.status    || 'PROBLEM').toUpperCase();\nconst eventId   = String(body.eventId   || '');\nconst timeRaw   = body.time ? parseInt(body.time) : Math.floor(Date.now()/1000);\nconst ts        = new Date(timeRaw * 1000).toLocaleString('es-CO',\n                    { timeZone:'America/Bogota', day:'2-digit', month:'2-digit',\n                      year:'2-digit', hour:'2-digit', minute:'2-digit' });\n\n// Iconos por severidad\nconst sevIcons = {\n  'not_classified': '⚪', 'information': 'ℹ️', 'warning': '⚠️',\n  'average': '🟠', 'high': '🔴', 'disaster': '💀'\n};\nconst sevIcon = sevIcons[severity] || '🔴';\n\nconst isResolved = status === 'RESOLVED' || status === 'OK';\nconst statusLine = isResolved\n  ? `✅ *RESUELTO*`\n  : `${sevIcon} *ALERTA — ${severity.toUpperCase()}*`;\n\nfunction escMd(s) { return String(s||'').replace(/[_*[\\]`]/g, c=>'\\\\'+c); }\n\nconst msg =\n  `${statusLine}\\n\\n` +\n  `🖥️ *Host:* ${escMd(hostName)}\\n` +\n  `📋 *Evento:* ${escMd(trigger)}\\n` +\n  (value ? `📊 *Valor:* ${escMd(value)}\\n` : '') +\n  `🕐 *Hora:* ${ts}`;\n\n// Callback para ver métricas del host afectado\nconst viewCallback = hostId ? `btn_alerta_host_${hostId}` : 'btn_menu';\nconst silenciarCallback = eventId ? `btn_silenciar_${eventId}` : 'btn_menu';\n\nconst reply_markup = JSON.stringify({ inline_keyboard: [\n  [{ text: '📈 Ver métricas del host', callback_data: viewCallback }],\n  isResolved\n    ? [{ text: '🏠 Ir al menú', callback_data: 'btn_menu' }]\n    : [{ text: '🔕 Silenciar 1h', callback_data: silenciarCallback },\n       { text: '🏠 Menú', callback_data: 'btn_menu' }]\n]});\n\n// Una salida por cada suscriptor registrado\nreturn subscribers.map(chatId => ({ chatId, mensaje: msg, reply_markup }));\n"
