        "jsCode": "// CHAMBALAND — Armar Mensajes v8 — Sin botón histórico + error futuro\nconst sesion_json = $node['🗂️ Gestor de Sesión'].json;\nconst accion  = sesion_json.accion;\nconst nombre  = sesion_json.nombre;\nconst host    = sesion_json.host || {};\nconst bucket  = sesion_json.bucket || null;\nconst chatId  = $node['Telegram Trigger'].json.message?.chat?.id?.toString()\n              || $node['Telegram Trigger'].json.callback_query?.message?.chat?.id?.toString();\n\nconst sesionRaw = $getWorkflowStaticData('global');\nif (!sesionRaw.sesiones) sesionRaw.sesiones = {};\n\nfunction mk(texto, markup) {\n  return { chatId, mensaje: texto, reply_markup: markup ? JSON.stringify(markup) : undefined };\n}\n\nswitch (accion) {\n\n  case 'mostrar_hosts': {\n    const hosts = $node['Zabbix - Obtener Hosts'].json.result || [];\n    sesionRaw.sesiones[chatId] = { ...(sesionRaw.sesiones[chatId]||{}), estado:'esperando_host', listaHosts:hosts };\n    sesionRaw.allHosts = hosts; // cache global — disponible para cross-host NLP en cualquier sesión\n    const botones = [];\n    for (let i = 0; i < hosts.length; i += 2) {\n      const fila = [{ text:'🖥️ '+hosts[i].name, callback_data:'btn_host_'+i }];\n      if (hosts[i+1]) fila.push({ text:'🖥️ '+hosts[i+1].name, callback_data:'btn_host_'+(i+1) });\n      botones.push(fila);\n    }\n    botones.push([{ text:'🌐 Todos los hosts', callback_data:'btn_todos' }]);\n    return mk(\n      `👋 ¡Hola *${nombre}*! Soy *CHAMBALAND* 🤖\\n\\nTu asistente de monitoreo y configuración de red.\\n\\n🖥️ *¿Qué host deseas revisar?*`,\n      { inline_keyboard: botones }\n    );\n  }\n\n  case 'mostrar_acciones': {\n    const sesionCompleta = sesionRaw.sesiones[chatId] || {};\n    const isSubscribed   = (sesionRaw.alertSubscribers || []).includes(chatId);\n    const alertBtn = isSubscribed\n      ? { text:'🔔 Alertas: ON',  callback_data:'btn_alertas' }\n      : { text:'🔕 Alertas: OFF', callback_data:'btn_alertas' };\n    return mk(\n      `✅ *${host.nombre || 'Host seleccionado'}*\\n\\n¿Qué deseas hacer?`,\n      { inline_keyboard: [\n        [{ text:'📊 Monitoreo', callback_data:'btn_monitoreo' }, { text:'⚙️ Configuración', callback_data:'btn_config' }],\n        [alertBtn],\n        [{ text:'🔄 Cambiar host', callback_data:'btn_menu' }]\n      ]}\n    );\n  }\n\n  case 'mostrar_metricas':\n  case 'mostrar_metricas_hist': {\n    const acumuladas = sesion_json.metricasAcumuladas || [];\n    // Mapeo de nombre de métrica acumulada → callback_data del botón\n    const _metricaToCallback = {\n      cpu:'btn_cpu', ram:'btn_ram', disco:'btn_disco', red:'btn_red',\n      os:'btn_os', temperatura:'btn_temperatura', security:'btn_security',\n      application:'btn_application', general:'btn_general',\n    };\n    const _cbElegidos = new Set(acumuladas.map(m => _metricaToCallback[m]).filter(Boolean));\n    const iconos  = { cpu:'🖥️', ram:'🧠', disco:'💾', red:'🌐', os:'🐧', temperatura:'🌡️', security:'🔐', general:'📋', application:'📦' };\n    const labels  = { cpu:'CPU', ram:'RAM', disco:'Disco', red:'Red', os:'Sistema', temperatura:'Temperatura', security:'Seguridad', general:'General', application:'Aplicaciones' };\n    const periodoTxt = bucket ? `\\n⏱️ *Período:* ${bucket.label}` : '';\n    const hayMetricas = acumuladas.length > 0;\n\n    const selTxt = hayMetricas\n      ? `\\n\\n✅ *Elegidas:* ${acumuladas.map(m=>(iconos[m]||'📊')+' '+(labels[m]||m)).join('  ')}\\n\\n👇 Agrega más o consulta:`\n      : `\\n\\n👇 *Selecciona qué deseas ver:*`;\n\n    // Prioridad 1: leer del flujo (output de Guardar Componentes — sin colisiones)\n    // Prioridad 2: fallback a estado estático (compatibilidad si el nodo no está en ruta)\n    // FIX v4: leer compDisp con fallback seguro a session state\n    const SKIP_COMP_MENU = new Set(['raw','gathering-process','internal-process','nvps','zabbix_internal','environment']);\n    const MIN_COMPS = ['cpu','memory','storage','network','os','system'];\n    let compDisp = null;\n    try { compDisp = $node['💡 Guardar Componentes'].json?.componentesDisponibles || null; } catch(_e) {}\n    if (!compDisp || compDisp.length === 0) {\n      const sesionCompleta = sesionRaw.sesiones[chatId] || {};\n      compDisp = sesionCompleta.componentesDisponibles || null;\n    }\n    // Filtrar componentes internos que no deben aparecer como botones\n    if (compDisp) {\n      compDisp = compDisp.filter(c => !SKIP_COMP_MENU.has(c));\n      // Si quedaron menos de 2, agregar los mínimos que falten\n      if (compDisp.length < 2) {\n        const compSet = new Set(compDisp);\n        for (const c of MIN_COMPS) { if (!compSet.has(c)) compDisp.push(c); }\n      }\n    }\n\n    const compABtn = {\n      cpu:         { text:'🖥️ CPU',          callback_data:'btn_cpu'         },\n      memory:      { text:'🧠 RAM',           callback_data:'btn_ram'         },\n      storage:     { text:'💾 Disco',         callback_data:'btn_disco'       },\n      network:     { text:'🌐 Red',           callback_data:'btn_red'         },\n      health:      { text:'🌐 Red',           callback_data:'btn_red'         },\n      os:          { text:'🐧 Sistema',       callback_data:'btn_os'          },\n      system:      { text:'🐧 Sistema',       callback_data:'btn_os'          },\n      temperature: { text:'🌡️ Temperatura',   callback_data:'btn_temperatura' },\n      security:    { text:'🔐 Seguridad',     callback_data:'btn_security'    },\n      application: { text:'📦 Aplicaciones',  callback_data:'btn_application' },\n      environment: { text:'🌍 Ambiente',      callback_data:'btn_environment' },\n    };\n\n    let botonesMetricas;\n    if (!compDisp || compDisp.length === 0) {\n      botonesMetricas = [\n        [{ text:'🖥️ CPU', callback_data:'btn_cpu' }, { text:'🧠 RAM', callback_data:'btn_ram' }],\n        [{ text:'💾 Disco', callback_data:'btn_disco' }, { text:'🌐 Red', callback_data:'btn_red' }],\n        [{ text:'🐧 Sistema', callback_data:'btn_os' }],\n        [{ text:'📋 Todo (General)', callback_data:'btn_general' }],\n      ].map(fila => fila.filter(btn => !_cbElegidos.has(btn.callback_data)))\n       .filter(fila => fila.length > 0);\n    } else {\n      const orden = ['cpu','memory','storage','network','health','os','system','temperature','security','application','environment'];\n      const compOrden = [...orden.filter(c=>compDisp.includes(c)), ...compDisp.filter(c=>!orden.includes(c))];\n      const btnsDisp = [];\n      const vistos = new Set();\n      for (const comp of compOrden) {\n        const btn = compABtn[comp];\n        if (btn && !vistos.has(btn.callback_data) && !_cbElegidos.has(btn.callback_data)) {\n          btnsDisp.push(btn);\n          vistos.add(btn.callback_data);\n        }\n      }\n      if (!_cbElegidos.has('btn_general')) {\n        btnsDisp.push({ text:'📋 Todo (General)', callback_data:'btn_general' });\n      }\n      botonesMetricas = [];\n      for (let i = 0; i < btnsDisp.length; i += 2) {\n        const fila = [btnsDisp[i]];\n        if (btnsDisp[i+1]) fila.push(btnsDisp[i+1]);\n        botonesMetricas.push(fila);\n      }\n    }\n\n    const botones = [...botonesMetricas];\n    if (hayMetricas) {\n      botones.push([\n        { text:'📊 Consultar en Texto', callback_data:'btn_texto' },\n        { text:'📄 Generar PDF',        callback_data:'btn_pdf'   }\n      ]);\n    }\n    botones.push([{ text:'🔙 Volver', callback_data:'btn_volver_acciones' }]);\n\n    const tipTxt = '\\n\\n_💡 Escribe, ej: \"CPU hace 3 horas\", \"RAM de ayer\", \"Red última semana\"_';\n\n    return mk(\n      `📊 *Monitoreo — ${host.nombre || 'Host'}*${periodoTxt}${selTxt}${tipTxt}`,\n      { inline_keyboard: botones }\n    );\n  }\n\n  case 'mostrar_periodo':\n    return mk(\n      `📈 *Consulta Histórica — ${host.nombre || 'Host'}*\\n\\n¿Qué período deseas analizar?`,\n      { inline_keyboard: [\n        [{ text:'⏱️ Últimas 2 horas',  callback_data:'btn_2h'   }, { text:'⏱️ Últimas 6 horas', callback_data:'btn_6h'  }],\n        [{ text:'📅 Últimas 24 horas', callback_data:'btn_24h'  }, { text:'📅 Últimos 7 días',   callback_data:'btn_7d'  }],\n        [{ text:'📆 Último mes',       callback_data:'btn_30d'  }, { text:'📆 Último año',        callback_data:'btn_365d'}],\n        [{ text:'🔙 Volver',          callback_data:'btn_volver_acciones' }]\n      ]}\n    );\n\n  case 'mostrar_config_menu':\n    return mk(\n      `⚙️ *Configuración — ${host.nombre || 'Host'}*\n\n` +\n      `📡 Muestra la configuración actual del host vía *SNMP/Zabbix*\\.\n\n` +\n      `¿Qué deseas consultar?`,\n      { inline_keyboard: [\n        [{ text:'📡 Interfaces de red',  callback_data:'btn_cfg_interfaces' },\n         { text:'💻 Sistema y uptime',   callback_data:'btn_cfg_sistema' }],\n        [{ text:'🗺️ Rutas y gateway',   callback_data:'btn_cfg_rutas' },\n         { text:'📊 Vista general',      callback_data:'btn_cfg_general' }],\n        [{ text:'🔙 Volver',             callback_data:'btn_volver_acciones' }]\n      ]}\n    );\n\n  case 'mostrar_config':\n    return mk(\n      `⚙️ *Configuración — ${host.nombre || 'Host'}*\\n\\n✍️ Escribe en lenguaje natural lo que deseas hacer:\\n\\n_Ejemplos:_\\n• _\"Cambia la IP a 192.168.1.50\"_\\n• _\"Desactiva el host\"_\\n• _\"Vincula el template Linux\"_\\n• _\"Dame info del host\"_`,\n      { inline_keyboard: [[{ text:'❌ Cancelar', callback_data:'btn_cancelar_config' }]] }\n    );\n\n  case 'alertas_menu': {\n    const isSub = (sesionRaw.alertSubscribers || []).includes(chatId);\n    return mk(\n      `🔔 *Alertas proactivas*\\n\\n`\n      + (isSub\n          ? `✅ Estás suscrito. El bot te avisará automáticamente cuando Zabbix detecte un problema en cualquier host.`\n          : `🔕 No estás suscrito. Actívalo para recibir alertas automáticas de Zabbix en este chat.`),\n      { inline_keyboard: [\n          isSub\n            ? [{ text:'🔕 Desactivar alertas', callback_data:'btn_unsub_alertas' }]\n            : [{ text:'🔔 Activar alertas',    callback_data:'btn_sub_alertas'   }],\n          [{ text:'🔙 Volver', callback_data:'btn_volver_acciones' }]\n        ]}\n    );\n  }\n\n  case 'sub_alertas': {\n    return mk(\n      `✅ *Alertas activadas*\\n\\nEste chat recibirá notificaciones automáticas cada vez que Zabbix detecte un problema crítico en cualquier host.\\n\\n`\n      + `_Puedes desactivarlas desde el menú de acciones → 🔔 Alertas_`,\n      { inline_keyboard: [[{ text:'🔙 Volver al menú', callback_data:'btn_volver_acciones' }]] }\n    );\n  }\n\n  case 'unsub_alertas': {\n    return mk(\n      `🔕 *Alertas desactivadas*\\n\\nEste chat ya no recibirá notificaciones automáticas de Zabbix.`,\n      { inline_keyboard: [[{ text:'🔙 Volver al menú', callback_data:'btn_volver_acciones' }]] }\n    );\n  }\n\n  case 'error_cross_host': {\n    const targetHost  = sesion_json.crossHostTarget || 'ese host';\n    const activeHost  = (sesion_json.host?.nombre || 'tu host actual');\n    return mk(\n      `⚠️ *Cambio de host requerido*\\n\\n`\n      + `Actualmente estás monitoreando *${activeHost}*.\\n`\n      + `Para consultar *${targetHost}* debes cambiarlo primero.\\n\\n`\n      + `👇 ¿Qué deseas hacer?`,\n      { inline_keyboard: [\n          [{ text: `🔀 Cambiar a ${targetHost}`, callback_data: 'btn_menu' }],\n          [{ text: `🔙 Seguir en ${activeHost}`, callback_data: 'btn_volver_metricas' }]\n        ]}\n    );\n  }\n\n  case 'error_futuro':\n    return mk(\n      `⏰ *No puedo consultar el futuro* 🔮\\n\\nSolo puedo analizar datos *históricos* o en *tiempo real*.\\n\\n_Prueba con:_\\n• _\"CPU hace 3 horas\"_\\n• _\"RAM de ayer\"_\\n• _\"Red la semana pasada\"_\\n• _\"Disco último mes\"_`,\n      { inline_keyboard: [\n        [{ text:'📊 Ver métricas actuales', callback_data:'btn_volver_metricas' }],\n        [{ text:'🔙 Volver', callback_data:'btn_volver_acciones' }]\n      ]}\n    );\n\n  case 'error_opcion': {\n    const sesionErr = sesionRaw.sesiones[chatId] || {};\n    const msgErr = sesionErr.mensajeError || '⚠️ No entendí esa opción.\\n\\nEscribe *hola* para reiniciar.